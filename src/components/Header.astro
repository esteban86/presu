---
// Header.astro — nav sticky con fondo glass (DS v2). Sin props por ahora.
import Logo from './Logo.astro';
---
<header class="site-header">
  <div class="wrap">
    <div class="row">
      <div class="brandlock">
        <Logo size="1.375rem" />
        <a class="endorse" href="https://asimetrica.co" target="_blank" rel="noopener" aria-label="de Asimétrica">
          <span>de</span>
          <img class="endorse-logo" src="/asimetrica-logo.webp" alt="Asimétrica" width="280" height="64" />
        </a>
      </div>

      <nav class="nav-links" id="nav-links" aria-label="Navegación principal">
        <a class="nav-link" href="/#como">Cómo</a>
        <a class="nav-link" href="/#privacidad">Privacidad</a>
        <a class="nav-link" href="/#planes">Planes</a>
        <a class="nav-link" href="/aporta">Aporta 🌱</a>
      </nav>

      <div class="nav-actions">
        <a class="btn-cta" href="/#waitlist">Únete a la lista</a>
        <button class="nav-burger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-links">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border);
  }

  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--screen-pad);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .brandlock {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .endorse {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--text-tertiary);
    text-decoration: none;
    padding-left: var(--space-3);
    border-left: 1px solid var(--border);
    white-space: nowrap;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .endorse-logo {
    height: 0.95rem;
    width: auto;
    display: block;
  }
  .endorse:hover .endorse-logo,
  .endorse:focus-visible .endorse-logo {
    opacity: 0.85;
  }

  .endorse:hover,
  .endorse:focus-visible {
    color: var(--text-secondary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  /* Botón hamburguesa (solo visible en móvil) */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 12px);
    cursor: pointer;
  }
  .nav-burger span {
    display: block;
    width: 20px;
    height: 2px;
    margin: 0 auto;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform var(--dur-fast) var(--ease-out), opacity var(--dur-fast) var(--ease-out);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--tap-min);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    background: var(--presu-emerald);
    color: var(--text-on-accent);
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    font-size: var(--text-label);
    text-decoration: none;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
    transition: background var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }

  .btn-cta:hover,
  .btn-cta:focus-visible {
    background: var(--presu-emerald-press);
    box-shadow: var(--shadow-accent);
  }

  /* Mobile: marca + CTA + hamburguesa; el nav pasa a menú desplegable (--bp-mobile: 640px) */
  @media (max-width: 640px) {
    .endorse {
      display: none;
    }

    .row {
      padding: var(--space-3) 0;
    }

    .btn-cta {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-caption);
    }

    .nav-burger {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-2) var(--screen-pad) var(--space-4);
      background: var(--bg-base, #08080A);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-bottom: 1px solid var(--border);
      display: none;
    }

    .site-header.is-open .nav-links {
      display: flex;
    }

    .nav-link {
      padding: var(--space-4) var(--space-1);
      font-size: 1.05rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-link:last-child {
      border-bottom: 0;
    }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const burger = header?.querySelector('.nav-burger');
  if (header && burger) {
    const close = () => {
      header.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
    };
    burger.addEventListener('click', () => {
      const open = header.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    header.querySelectorAll('.nav-links a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }
</script>
