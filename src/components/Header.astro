---
// Header.astro — nav sticky con fondo glass (DS v2). Sin props por ahora.
import Logo from './Logo.astro';
---
<header class="site-header">
  <div class="wrap">
    <div class="row">
      <div class="brandlock">
        <Logo size="1.375rem" />
        <a class="endorse" href="https://asimetrica.co" target="_blank" rel="noopener">
          de Asimétrica
        </a>
      </div>

      <nav class="nav-links" aria-label="Navegación principal">
        <a class="nav-link" href="/#como">Cómo</a>
        <a class="nav-link" href="/#privacidad">Privacidad</a>
        <a class="nav-link" href="/#planes">Planes</a>
        <a class="nav-link" href="/aporta">Aporta 🌱</a>
      </nav>

      <div class="nav-actions">
        <a class="btn-cta" href="/#waitlist">Únete a la lista</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border);
  }

  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--screen-pad);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .brandlock {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .endorse {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--text-tertiary);
    text-decoration: none;
    padding-left: var(--space-3);
    border-left: 1px solid var(--border);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .endorse:hover,
  .endorse:focus-visible {
    color: var(--text-secondary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--tap-min);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    background: var(--presu-emerald);
    color: var(--text-on-accent);
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    font-size: var(--text-label);
    text-decoration: none;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
    transition: background var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }

  .btn-cta:hover,
  .btn-cta:focus-visible {
    background: var(--presu-emerald-press);
    box-shadow: var(--shadow-accent);
  }

  /* Mobile: colapsa a lo esencial — marca + CTA (mirrors --bp-mobile: 640px) */
  @media (max-width: 640px) {
    .endorse,
    .nav-links {
      display: none;
    }

    .row {
      padding: var(--space-3) 0;
    }

    .btn-cta {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-caption);
    }
  }
</style>
