---
// BudgetBar.astro — línea de presupuesto por categoría: label + gastado/
// total + barra de progreso. Se sobrepasa el 100% -> se tiñe de rose y
// muestra la nota "over".
export interface Props {
  label: string;
  emoji?: string;
  spent?: string;
  total?: string;
  pct?: number;
  color?: string;
  over?: string;
}

const {
  label,
  emoji,
  spent,
  total,
  pct = 0,
  color = 'var(--presu-emerald)',
  over,
} = Astro.props;

const clamped = Math.min(100, Math.max(0, pct));
const isOver = pct > 100 || Boolean(over);
const fillColor = isOver ? 'var(--color-negative)' : color;
const fillWidth = isOver ? 100 : clamped;
---

<div class="budget-bar">
  <div class="budget-bar__row">
    {emoji && <span class="budget-bar__emoji">{emoji}</span>}
    <span class="budget-bar__label">{label}</span>
    <span class:list={['budget-bar__amounts', { 'budget-bar__amounts--over': isOver }]}>
      {spent}{total ? ` / ${total}` : ''}
    </span>
  </div>
  <div class="budget-bar__track">
    <div class="budget-bar__fill" style={`width:${fillWidth}%; background:${fillColor};`}></div>
  </div>
  {over && <div class="budget-bar__over">{over}</div>}
</div>

<style>
  .budget-bar__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .budget-bar__emoji {
    font-size: 17px;
    line-height: 1;
  }

  .budget-bar__label {
    flex: 1;
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    font-size: var(--text-body);
    color: var(--text-primary);
  }

  .budget-bar__amounts {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .budget-bar__amounts--over {
    color: var(--color-negative);
  }

  .budget-bar__track {
    height: 7px;
    border-radius: var(--radius-full);
    background: var(--bg-raised);
    overflow: hidden;
  }

  .budget-bar__fill {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width var(--dur-slow) var(--ease-out);
  }

  .budget-bar__over {
    margin-top: var(--space-1);
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-negative);
  }
</style>
