---
// Showcase — "Mira lo que verás por dentro"
// Sección de vistas de la app (mockups en HTML/CSS/SVG). Autocontenida: trae sus
// propios tokens y CSS con <style> scoped de Astro (aislado del resto del landing).
// Portada desde la landing estática (main:index.html) a la migración Astro.
---

<section class="presu-showcase">
  <div class="wrap">
    <div class="sec-head reveal"><span class="eyebrow center-eb">Funciones</span><h2>Mira lo que verás por dentro</h2></div>

    <div class="show">

      <!-- A · Ventana completa de la app (Inicio) — pieza "wow" -->
      <div class="appwin-block">
      <div class="appwin reveal">
        <div class="appwin__glow" aria-hidden="true"></div>
        <div class="appwin__frame">
          <div class="appwin__bar">
            <span class="appwin__dots"><i></i><i></i><i></i></span>
            <span class="appwin__addr">Presu · escritorio</span>
            <span class="appwin__badge"><span class="gd"></span> Local</span>
          </div>
          <div class="appwin__body">
            <aside class="aw-side">
              <div class="aw-brand">
                <span class="aw-wm"><span class="aw-wmbar" aria-hidden="true"></span>presu</span>
                <span class="aw-tag">Tu plata, clara</span>
              </div>
              <span class="aw-import">＋&nbsp;&nbsp;Importar</span>
              <nav class="aw-nav">
                <span class="aw-nav-i on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Inicio</span>
                <span class="aw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4v16M7 4 4 7M7 4l3 3M17 20V4M17 20l-3-3M17 20l3-3"/></svg>Transacciones</span>
                <span class="aw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>Presupuestos</span>
                <span class="aw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M8 17v-5"/><path d="M13 17V8"/><path d="M18 17v-9"/></svg>Análisis</span>
                <span class="aw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>Importaciones</span>
                <span class="aw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0l-7.2-7.2A2 2 0 0 1 3 12V5a2 2 0 0 1 2-2h7a2 2 0 0 1 1.4.6l7.2 7.2a2 2 0 0 1 0 2.8z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>Categorías</span>
              </nav>
              <div class="aw-local">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <div><b>Local-first</b><span>Tus datos viven cifrados aquí, en tu equipo.</span></div>
              </div>
            </aside>
            <main class="aw-main">
              <div class="aw-head"><h3>Inicio</h3><span class="aw-date">2026-06-01 → 06-30</span></div>
              <div class="dash-top">
                <span class="m-chip">📅 Mes actual ▾</span>
                <span class="m-chip">Todas las cuentas ▾</span>
                <span class="m-chip"><span class="gd"></span> 12 visitas este mes</span>
              </div>
              <div class="verdict-line">
                <span class="vl-tag"><span class="vl-dot"></span> Vas bien</span>
                <p class="vl-txt">Hasta ahora <b>te sobran $1.680.000</b> de lo que entró este mes.</p>
              </div>
              <div class="stat-grid">
                <div class="stat">
                  <div class="sl" style="color:var(--mint-bright)">↗ Ingresos</div>
                  <svg class="spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,20 12,17 24,18 36,10 48,7 60,9 72,4" fill="none" stroke="var(--mint-bright)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <div class="sv" style="color:var(--mint-bright)">$6.420.000</div>
                  <div class="sd"><b style="color:var(--mint-bright)">↑ 9.2%</b> vs mes ant.</div>
                </div>
                <div class="stat">
                  <div class="sl" style="color:var(--coral)">↘ Gastos</div>
                  <svg class="spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,8 12,6 24,12 36,7 48,14 60,11 72,16" fill="none" stroke="var(--coral)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <div class="sv" style="color:var(--coral)">$4.740.000</div>
                  <div class="sd"><b style="color:var(--mint-bright)">↓ 8.4%</b> vs mes ant.</div>
                </div>
                <div class="stat">
                  <div class="sl" style="color:var(--indigo-soft)">▦ Balance</div>
                  <svg class="spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,18 12,20 24,13 36,15 48,9 60,11 72,5" fill="none" stroke="var(--indigo-soft)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <div class="sv" style="color:var(--indigo-soft)">$1.680.000</div>
                  <div class="sd"><b style="color:var(--mint-bright)">↑ 138.5%</b> vs mes ant.</div>
                </div>
              </div>
              <div class="budget-hd"><span class="bt">Presupuestos del mes</span><span class="bn">$4.740.000 / $5.700.000 · 83%</span></div>
              <div class="rings">
                <div class="ring"><div class="rc" style="--rc-color:var(--amber);--target:83%;--k:0"><b>83%</b></div><span class="rt">Vivienda</span><span class="rb">1,8M</span></div>
                <div class="ring"><div class="rc" style="--rc-color:var(--amber);--target:90%;--k:1"><b>90%</b></div><span class="rt">Alimentación</span><span class="rb">1,0M</span></div>
                <div class="ring"><div class="rc" style="--rc-color:var(--mint);--target:60%;--k:2"><b>60%</b></div><span class="rt">Salud</span><span class="rb">700K</span></div>
                <div class="ring"><div class="rc" style="--rc-color:var(--mint);--target:64%;--k:3"><b>64%</b></div><span class="rt">Hija</span><span class="rb">500K</span></div>
                <div class="ring"><div class="rc" style="--rc-color:var(--mint);--target:45%;--k:4"><b>45%</b></div><span class="rt">Familia</span><span class="rb">900K</span></div>
                <div class="ring"><div class="rc" style="--rc-color:var(--mint);--target:70%;--k:5"><b>70%</b></div><span class="rt">Entretenim.</span><span class="rb">800K</span></div>
              </div>
            </main>
          </div>
        </div>
      </div>
      <p class="appwin-cap"><b>Así se ve tu Inicio.</b> La respuesta primero —cuánto entró, cuánto salió y si vas bien— con la variación contra el mes pasado y tus presupuestos por categoría en anillos. Todo local, en tu equipo.</p>
      </div>

      <!-- B · Ritmo de gasto -->
      <div class="show-row rev reveal">
        <div class="show-copy">
          <span class="eyebrow">¿Vas a llegar a fin de mes?</span>
          <h3>Tu ritmo de gasto, contra lo esperado</h3>
          <p>Presu dibuja lo que llevas gastado (línea verde) sobre lo que deberías ir gastando (punteada) y tu techo de presupuesto. Si vas muy rápido, lo ves días antes —no cuando ya es tarde.</p>
          <ul class="show-list">
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Gasto real vs. ritmo esperado, día a día</li>
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Techo de presupuesto siempre a la vista</li>
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Proyección de cómo cerrarás el mes</li>
          </ul>
        </div>
        <div class="show-art">
          <div class="panel-glow" style="background:linear-gradient(120deg,#34D399,#818CF8)"></div>
          <div class="panel">
            <span class="panel-cap">Ritmo de gasto</span>
            <div class="chart-hd"><span class="ct">Ritmo de Gasto</span><span class="cl">Ver análisis →</span></div>
            <div style="position:relative">
              <svg viewBox="0 0 340 184" width="100%" style="display:block" role="img" aria-label="Gráfica de ritmo de gasto">
                <defs>
                  <linearGradient id="realfill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#34D399" stop-opacity=".30"/><stop offset="1" stop-color="#34D399" stop-opacity="0"/></linearGradient>
                  <linearGradient id="lineg" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#FBBF24"/><stop offset=".5" stop-color="#9BE15D"/><stop offset="1" stop-color="#34D399"/></linearGradient>
                </defs>
                <line x1="30" y1="24" x2="332" y2="24" stroke="rgba(255,255,255,.05)"/>
                <line x1="30" y1="87" x2="332" y2="87" stroke="rgba(255,255,255,.05)"/>
                <line x1="30" y1="150" x2="332" y2="150" stroke="rgba(255,255,255,.09)"/>
                <line x1="30" y1="35" x2="332" y2="35" stroke="#FB7185" stroke-width="1.6" stroke-dasharray="6 5" opacity=".7"/>
                <path d="M30 148 C80 130 110 112 150 100 C200 84 270 54 326 42" fill="none" stroke="rgba(255,255,255,.42)" stroke-width="2.2" stroke-dasharray="6 5"/>
                <path class="area-fade" d="M30 140 C66 132 92 116 120 108 C156 98 182 95 210 86 L210 150 L30 150 Z" fill="url(#realfill)"/>
                <path class="grow-line" pathLength="1" d="M30 140 C66 132 92 116 120 108 C156 98 182 95 210 86" fill="none" stroke="url(#lineg)" stroke-width="3.6" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="210" y1="22" x2="210" y2="150" stroke="#8B8DF7" stroke-width="1.4" stroke-dasharray="4 4" opacity=".55"/>
                <circle class="land-pulse" cx="210" cy="86" r="8.5" fill="#34D399" opacity=".25" style="transform-box:fill-box;transform-origin:center"/>
                <circle class="land-dot" cx="210" cy="86" r="5" fill="#34D399" stroke="#0A0A0C" stroke-width="2.2"/>
                <line x1="300" y1="35" x2="300" y2="150" stroke="rgba(255,255,255,.12)" stroke-width="1"/>
                <circle cx="300" cy="44" r="4" fill="#9A9AA6" stroke="#0A0A0C" stroke-width="2"/>
                <text x="4" y="27" fill="#6B6B76" font-size="8.5" font-family="JetBrains Mono">6M</text>
                <text x="4" y="90" fill="#6B6B76" font-size="8.5" font-family="JetBrains Mono">3M</text>
                <text x="4" y="152" fill="#6B6B76" font-size="8.5" font-family="JetBrains Mono">0</text>
                <text x="28" y="167" fill="#6B6B76" font-size="8.5" font-family="JetBrains Mono">Día 1</text>
                <text x="195" y="167" fill="#8B8DF7" font-size="8.5" font-weight="600" font-family="JetBrains Mono">Hoy</text>
                <text x="284" y="167" fill="#6B6B76" font-size="8.5" font-family="JetBrains Mono">Día 27</text>
              </svg>
              <div class="chart-pill pop" style="left:45%;top:24%">$268.000 por debajo</div>
            </div>
            <div class="chart-legend">
              <span><i style="border:0;height:3px;width:18px;border-radius:2px;background:linear-gradient(90deg,#FBBF24,#34D399)"></i> Real</span>
              <span><i style="border-color:rgba(255,255,255,.45);border-top-style:dashed"></i> Tu ritmo de costumbre</span>
              <span><i style="border-color:#FB7185;border-top-style:dashed"></i> Techo del presupuesto</span>
            </div>
          </div>
        </div>
      </div>

      <!-- C · Sincronización con correo -->
      <div class="show-row reveal">
        <div class="show-copy">
          <span class="eyebrow">Sin trabajo manual</span>
          <h3>Importa solo, desde tu correo</h3>
          <p>Conecta tu correo y Presu encuentra las notificaciones del banco y los extractos PDF que ya te llegaron, los lee y los importa —saltándose los duplicados. Y todo el procesamiento ocurre en tu equipo.</p>
          <ul class="show-list">
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Gmail, Outlook, Yahoo e iCloud</li>
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Encuentra y procesa extractos PDF automáticamente</li>
            <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Detecta duplicados para no repetir movimientos</li>
          </ul>
        </div>
        <div class="show-art">
          <div class="panel-glow" style="background:linear-gradient(120deg,#818CF8,#A855F7)"></div>
          <div class="panel">
            <span class="panel-cap">Sincronización</span>
            <div class="sync-hd"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg> Sincronización con tu correo</div>
            <div class="sync-stat">270 transacciones importadas desde el correo</div>
            <div class="sync-period"><span class="p">⚡ 24 horas</span><span class="p on">7 días</span><span class="p">30 días</span><span class="p">90 días</span></div>
            <div class="sync-status"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg> Gmail conectado (OAuth)</div>
            <div class="sync-banks">Extractos PDF: <span class="bk">Bancolombia</span><span class="bk">Davivienda</span><span class="bk">Nu</span><span class="bk">RappiCard</span></div>
            <div class="prog-row"><span>10/20 correos · <span style="color:var(--mint-bright)">6 importadas</span> · 4 omitidas</span><span>50%</span></div>
            <div class="prog"><i></i></div>
            <div class="console">
              <div>7:59:21 p.m. [1/20] <span class="imp">Importada: NONNA MALL DEL ESTE</span></div>
              <div>7:59:21 p.m. [2/20] <span class="dup">Duplicado: BOLD CO SAS</span></div>
              <div>7:59:22 p.m. [3/20] <span class="imp">Importada: D1 CRA 70 — $48.900</span></div>
              <div>7:59:22 p.m. [4/20] <span class="imp">Importada: RAPPI COL — $32.500</span></div>
              <div>7:59:23 p.m. [5/20] <span class="dup">Duplicado: UBER BV USD-USD COLO</span></div>
              <div>7:59:23 p.m. [6/20] <span class="imp">Importada: ÉXITO POBLADO — $124.300</span></div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="feat-extra reveal">
      <span class="x"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 3 1.9 4.6L19 8.3l-3.7 3.3 1 5L12 14.5 7.7 16.6l1-5L5 8.3l5.1-.7z"/></svg>Categorización con IA</span>
      <span class="x"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>Flujo de caja y patrimonio</span>
      <span class="x"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>Exporta a Excel o CSV</span>
      <span class="x"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Multi-dispositivo</span>
    </div>
  </div>
</section>

<style>
  /* Tokens (aislados a esta sección — el DS v2 renombró los globales) */
  .presu-showcase{
    --indigo:#818CF8; --indigo-soft:#A5B4FC; --mint:#34D399; --mint-bright:#5EEAB8; --coral:#FB7185; --amber:#FBBF24;
    --bg-2:#101014; --bg-3:#141418; --bg-elev:#1B1B20;
    --line:rgba(255,255,255,.07); --line-2:rgba(255,255,255,.12);
    --tx:#F4F4F3; --mut:#A1A1A6; --mut2:#6B6B72;
    --radius:20px; --maxw:1160px;
    --head:"Space Grotesk",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --sh-lg:0 1px 0 rgba(255,255,255,.05) inset, 0 40px 90px -40px rgba(0,0,0,.85);
    position:relative; padding:clamp(72px,9vw,112px) 0;
  }
  .presu-showcase .wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}
  .presu-showcase h2{font-family:var(--head);font-weight:700;line-height:1.08;letter-spacing:-0.03em;color:#fff;font-size:clamp(1.8rem,3.8vw,2.6rem);margin:0 0 14px}
  .presu-showcase h3{font-family:var(--head);color:#fff}
  .presu-showcase .sec-head{max-width:680px;margin:0 auto 52px;text-align:center;position:relative;z-index:2}
  .presu-showcase .eyebrow{display:inline-flex;align-items:center;gap:11px;font-family:var(--mono);font-size:.7rem;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--mint);margin-bottom:18px}
  .presu-showcase .eyebrow::before{content:"";width:24px;height:1.5px;background:var(--mint-bright);opacity:.6;display:inline-block}
  .presu-showcase .eyebrow.center-eb{justify-content:center}

  /* ── Feature showcase ── */
  .presu-showcase .show{display:flex;flex-direction:column;gap:88px}
  .presu-showcase .show-row{display:grid;grid-template-columns:.92fr 1.08fr;gap:56px;align-items:center}
  .presu-showcase .show-row.rev .show-copy{order:2}
  .presu-showcase .show-row.rev .show-art{order:1}
  .presu-showcase .show-copy h3{font-family:var(--head);font-weight:700;font-size:clamp(1.5rem,3vw,2.05rem);letter-spacing:-0.03em;color:#fff;margin:0 0 12px;line-height:1.1}
  .presu-showcase .show-copy>p{color:var(--mut);font-size:1.06rem;margin:0 0 18px;max-width:46ch}
  .presu-showcase .show-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:11px}
  .presu-showcase .show-list li{display:flex;gap:10px;align-items:flex-start;color:var(--tx);font-size:.97rem}
  .presu-showcase .show-list svg{color:var(--mint-bright);flex:none;margin-top:3px}
  .presu-showcase .show-art{position:relative}
  .presu-showcase .panel-glow{position:absolute;inset:-14% -10%;border-radius:50%;filter:blur(74px);opacity:.4;z-index:0}
  .presu-showcase .panel{background:linear-gradient(180deg,var(--bg-3),var(--bg-2));border:1px solid var(--line-2);border-radius:var(--radius);box-shadow:var(--sh-lg);padding:18px;position:relative;z-index:2}
  .presu-showcase .panel-cap{position:absolute;top:-11px;left:20px;z-index:3;background:rgba(52,211,153,.14);border:1px solid rgba(52,211,153,.34);color:var(--mint);font-family:var(--mono);font-size:.6rem;font-weight:500;padding:4px 10px;border-radius:999px;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap}

  /* dashboard mock */
  .presu-showcase .dash-top{display:flex;gap:7px;flex-wrap:wrap;align-items:center;margin-bottom:13px}
  .presu-showcase .m-chip{display:inline-flex;align-items:center;gap:6px;background:var(--bg-elev);border:1px solid var(--line);border-radius:9px;padding:6px 10px;font-size:.72rem;color:var(--mut);font-weight:500}
  .presu-showcase .m-chip .gd{width:6px;height:6px;border-radius:50%;background:var(--mint)}
  .presu-showcase .dash-date{margin-left:auto;font-size:.66rem;color:var(--mut2);font-variant-numeric:tabular-nums}
  .presu-showcase .stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:14px}
  .presu-showcase .stat{position:relative;overflow:hidden;background:var(--bg-elev);border:1px solid var(--line);border-radius:12px;padding:12px 13px}
  .presu-showcase .spark{position:absolute;top:12px;right:12px;width:56px;height:20px;opacity:.85}
  .presu-showcase .verdict-line{background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.22);border-radius:12px;padding:11px 14px;margin-bottom:13px}
  .presu-showcase .vl-tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.58rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--mint)}
  .presu-showcase .vl-dot{width:6px;height:6px;border-radius:50%;background:var(--mint);box-shadow:0 0 7px var(--mint)}
  .presu-showcase .vl-txt{margin:6px 0 0;font-family:var(--head);font-weight:700;font-size:1rem;line-height:1.3;color:#fff}
  .presu-showcase .vl-txt b{color:var(--mint-bright)}
