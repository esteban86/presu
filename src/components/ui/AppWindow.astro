---
// AppWindow.astro — mockup de la VENTANA completa de Presu escritorio (pantalla
// "Inicio"): barra de título + sidebar + dashboard. Fiel a la app real, con
// datos ficticios coherentes ($6,42M − $4,74M = $1,68M; presupuestos suman $5,7M).
// Autocontenido (tokens + estilos scoped). Los anillos se llenan al entrar en
// viewport (clase .in que inyecta el observer .reveal del landing).
import Logo from '../Logo.astro';
---

<div class="pw reveal">
  <div class="pw__glow" aria-hidden="true"></div>
  <div class="pw__frame">
    <div class="pw__bar">
      <span class="pw__dots"><i></i><i></i><i></i></span>
      <span class="pw__addr">Presu · escritorio</span>
      <span class="pw__badge"><span class="gd"></span> Local</span>
    </div>
    <div class="pw__body">
      <aside class="pw-side">
        <div class="pw-brand">
          <Logo size="1.15rem" href={null} />
          <span class="pw-tag">Tu plata, clara</span>
        </div>
        <span class="pw-import">＋&nbsp;&nbsp;Importar</span>
        <nav class="pw-nav">
          <span class="pw-nav-i on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Inicio</span>
          <span class="pw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4v16M7 4 4 7M7 4l3 3M17 20V4M17 20l-3-3M17 20l3-3"/></svg>Transacciones</span>
          <span class="pw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>Presupuestos</span>
          <span class="pw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M8 17v-5"/><path d="M13 17V8"/><path d="M18 17v-9"/></svg>Análisis</span>
          <span class="pw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>Importaciones</span>
          <span class="pw-nav-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0l-7.2-7.2A2 2 0 0 1 3 12V5a2 2 0 0 1 2-2h7a2 2 0 0 1 1.4.6l7.2 7.2a2 2 0 0 1 0 2.8z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>Categorías</span>
        </nav>
        <div class="pw-local">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div><b>Local-first</b><span>Tus datos viven cifrados aquí, en tu equipo.</span></div>
        </div>
      </aside>
      <main class="pw-main">
        <div class="pw-head"><h3>Inicio</h3><span class="pw-date">2026-06-01 → 06-30</span></div>
        <div class="pw-chips">
          <span class="pw-chip">📅 Mes actual ▾</span>
          <span class="pw-chip">Todas las cuentas ▾</span>
          <span class="pw-chip"><span class="gd"></span> 12 visitas este mes</span>
        </div>
        <div class="pw-verdict">
          <span class="pw-vtag"><span class="pw-vdot"></span> Vas bien</span>
          <p class="pw-vtxt">Hasta ahora <b>te sobran $1.680.000</b> de lo que entró este mes.</p>
        </div>
        <div class="pw-stats">
          <div class="pw-stat">
            <div class="pw-sl" style="color:var(--mint-bright)">↗ Ingresos</div>
            <svg class="pw-spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,20 12,17 24,18 36,10 48,7 60,9 72,4" fill="none" stroke="var(--mint-bright)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="pw-sv" style="color:var(--mint-bright)">$6.420.000</div>
            <div class="pw-sd"><b style="color:var(--mint-bright)">↑ 9.2%</b> vs mes ant.</div>
          </div>
          <div class="pw-stat">
            <div class="pw-sl" style="color:var(--coral)">↘ Gastos</div>
            <svg class="pw-spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,8 12,6 24,12 36,7 48,14 60,11 72,16" fill="none" stroke="var(--coral)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="pw-sv" style="color:var(--coral)">$4.740.000</div>
            <div class="pw-sd"><b style="color:var(--mint-bright)">↓ 8.4%</b> vs mes ant.</div>
          </div>
          <div class="pw-stat">
            <div class="pw-sl" style="color:var(--indigo-soft)">▦ Balance</div>
            <svg class="pw-spark" viewBox="0 0 72 26" preserveAspectRatio="none" aria-hidden="true"><polyline points="0,18 12,20 24,13 36,15 48,9 60,11 72,5" fill="none" stroke="var(--indigo-soft)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="pw-sv" style="color:var(--indigo-soft)">$1.680.000</div>
            <div class="pw-sd"><b style="color:var(--mint-bright)">↑ 138.5%</b> vs mes ant.</div>
          </div>
        </div>
        <div class="pw-bhd"><span class="pw-bt">Presupuestos del mes</span><span class="pw-bn">$4.740.000 / $5.700.000 · 83%</span></div>
        <div class="pw-rings">
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--amber);--target:83%;--k:0"><b>83%</b></div><span class="pw-rt">Vivienda</span><span class="pw-rb">1,8M</span></div>
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--amber);--target:90%;--k:1"><b>90%</b></div><span class="pw-rt">Alimentación</span><span class="pw-rb">1,0M</span></div>
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--mint);--target:60%;--k:2"><b>60%</b></div><span class="pw-rt">Salud</span><span class="pw-rb">700K</span></div>
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--mint);--target:64%;--k:3"><b>64%</b></div><span class="pw-rt">Hija</span><span class="pw-rb">500K</span></div>
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--mint);--target:45%;--k:4"><b>45%</b></div><span class="pw-rt">Familia</span><span class="pw-rb">900K</span></div>
          <div class="pw-ring"><div class="pw-rc" style="--rc-color:var(--mint);--target:70%;--k:5"><b>70%</b></div><span class="pw-rt">Entretenim.</span><span class="pw-rb">800K</span></div>
        </div>
      </main>
    </div>
  </div>
</div>

<style>
  .pw{
    --indigo:#818CF8; --indigo-soft:#A5B4FC; --mint:#34D399; --mint-bright:#5EEAB8; --coral:#FB7185; --amber:#FBBF24;
    --bg-2:#101014; --bg-3:#141418; --bg-elev:#1B1B20; --line:rgba(255,255,255,.07); --line-2:rgba(255,255,255,.12);
    --tx:#F4F4F3; --mut:#A1A1A6; --mut2:#6B6B72;
    --head:"Space Grotesk",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    position:relative; width:100%;
  }
  .pw__glow{position:absolute;inset:-7% -4% 4%;border-radius:40px;background:linear-gradient(120deg,#818CF8,#34D399);filter:blur(80px);opacity:.24;z-index:0}
  .pw__frame{position:relative;z-index:1;border:1px solid var(--line-2);border-radius:16px;overflow:hidden;background:var(--bg-2);box-shadow:0 1px 0 rgba(255,255,255,.05) inset,0 40px 90px -40px rgba(0,0,0,.85)}
  .pw__bar{display:flex;align-items:center;gap:12px;padding:10px 15px;background:#0C0C10;border-bottom:1px solid var(--line)}
  .pw__dots{display:inline-flex;gap:7px}
  .pw__dots i{width:11px;height:11px;border-radius:50%}
  .pw__dots i:nth-child(1){background:#FF5F57}
  .pw__dots i:nth-child(2){background:#FEBC2E}
  .pw__dots i:nth-child(3){background:#28C840}
  .pw__addr{font-family:var(--mono);font-size:.64rem;color:var(--mut2);letter-spacing:.04em}
  .pw__badge{margin-left:auto;display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.58rem;text-transform:uppercase;letter-spacing:.1em;color:var(--mint)}
  .pw .gd{width:6px;height:6px;border-radius:50%;background:var(--mint);box-shadow:0 0 7px var(--mint)}
  .pw__body{display:grid;grid-template-columns:186px 1fr}

  .pw-side{display:flex;flex-direction:column;gap:13px;padding:16px 12px;background:#0A0A0D;border-right:1px solid var(--line)}
  .pw-brand{display:flex;flex-direction:column;gap:4px}
  .pw-tag{font-family:var(--mono);font-size:.5rem;letter-spacing:.14em;text-transform:uppercase;color:var(--mut2)}
  .pw-import{display:flex;align-items:center;justify-content:center;background:var(--mint);color:#06231A;font-family:var(--head);font-weight:700;font-size:.8rem;border-radius:10px;padding:9px}
  .pw-nav{display:flex;flex-direction:column;gap:2px;margin-top:2px}
  .pw-nav-i{display:flex;align-items:center;gap:9px;padding:7px 9px;border-radius:9px;font-size:.8rem;color:var(--mut);font-weight:500}
  .pw-nav-i svg{width:15px;height:15px;flex:none;opacity:.8}
  .pw-nav-i.on{background:rgba(52,211,153,.12);color:var(--mint-bright)}
  .pw-local{display:flex;gap:8px;margin-top:auto;padding:10px;border:1px solid rgba(52,211,153,.2);border-radius:10px;background:rgba(52,211,153,.05)}
  .pw-local svg{width:14px;height:14px;flex:none;color:var(--mint);margin-top:1px}
  .pw-local b{display:block;font-family:var(--head);font-size:.7rem;color:var(--mint-bright);margin-bottom:2px}
  .pw-local span{font-size:.6rem;color:var(--mut);line-height:1.4}

  .pw-main{padding:18px 20px;min-width:0}
  .pw-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px}
  .pw-head h3{font-family:var(--head);font-weight:700;font-size:1.4rem;color:#fff;margin:0;letter-spacing:-.02em}
  .pw-date{font-family:var(--mono);font-size:.62rem;color:var(--mut2)}
  .pw-chips{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:13px}
  .pw-chip{display:inline-flex;align-items:center;gap:6px;background:var(--bg-elev);border:1px solid var(--line);border-radius:9px;padding:6px 10px;font-size:.7rem;color:var(--mut);font-weight:500}

  .pw-verdict{background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.22);border-radius:12px;padding:11px 14px;margin-bottom:13px}
  .pw-vtag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.58rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--mint)}
  .pw-vdot{width:6px;height:6px;border-radius:50%;background:var(--mint);box-shadow:0 0 7px var(--mint)}
  .pw-vtxt{margin:6px 0 0;font-family:var(--head);font-weight:700;font-size:1rem;line-height:1.3;color:#fff}
  .pw-vtxt b{color:var(--mint-bright)}

  .pw-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:14px}
  .pw-stat{position:relative;overflow:hidden;background:var(--bg-elev);border:1px solid var(--line);border-radius:12px;padding:12px 13px}
  .pw-sl{display:flex;align-items:center;gap:6px;font-size:.7rem;color:var(--mut);font-weight:600;margin-bottom:7px}
  .pw-sv{font-family:var(--head);font-weight:800;font-size:1.12rem;letter-spacing:-.02em;font-variant-numeric:tabular-nums}
  .pw-sd{font-size:.62rem;color:var(--mut2);margin-top:5px}
  .pw-spark{position:absolute;top:12px;right:12px;width:54px;height:19px;opacity:.85}

  .pw-bhd{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px;font-size:.74rem}
  .pw-bt{font-family:var(--head);font-weight:700;color:#fff;font-size:.84rem}
  .pw-bn{color:var(--mut2);font-variant-numeric:tabular-nums}
  .pw-rings{display:flex;gap:9px;overflow-x:auto}
  .pw-ring{display:flex;flex-direction:column;align-items:center;gap:5px;flex:1;min-width:0}
  .pw-rc{width:50px;height:50px;border-radius:50%;display:grid;place-items:center;position:relative;background:conic-gradient(var(--rc-color,var(--mint)) var(--target,0%),rgba(255,255,255,.08) 0)}
  .pw-rc::after{content:"";position:absolute;inset:6px;background:#0A0A0D;border-radius:50%}
  .pw-rc b{position:relative;z-index:1;font-size:.64rem;font-weight:700;color:var(--tx)}
  .pw-rt{font-size:.58rem;color:var(--mut);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
  .pw-rb{font-family:var(--mono);font-size:.54rem;color:var(--mut2)}

  /* Anillos se llenan al entrar en viewport */
  @property --pwfill { syntax: '<percentage>'; inherits: false; initial-value: 0%; }
  @media (prefers-reduced-motion: no-preference){
    .pw.in .pw-rc{
      background:conic-gradient(var(--rc-color,var(--mint)) var(--pwfill),rgba(255,255,255,.08) 0);
      animation:pw-fill 1s cubic-bezier(.2,.7,.2,1) calc(.15s + var(--k,0) * .09s) both;
    }
    @keyframes pw-fill{from{--pwfill:0%}to{--pwfill:var(--target,0%)}}
  }

  @media(max-width:640px){
    .pw__body{grid-template-columns:1fr}
    .pw-side{display:none}
    .pw-main{padding:15px}
    .pw-head h3{font-size:1.2rem}
    .pw-stats{grid-template-columns:1fr}
  }
</style>
