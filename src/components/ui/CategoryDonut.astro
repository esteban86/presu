---
// CategoryDonut.astro — dona de gastos por categoría (conic-gradient) + leyenda.
// Portado del visual firma de la landing en vivo ("¿en qué se me va la plata?").
// Recibe segmentos ya formateados (mismo contrato que los demás componentes de ui/).
export interface Segment {
  label: string;
  emoji: string;
  amount: string; // string ya formateado, ej. "$1.640.000"
  value: number; // valor crudo para calcular la proporción
  color: string; // token o hex
}
export interface Props {
  segments: Segment[];
  total: string; // total ya formateado para el centro, ej. "$9,14M"
  caption?: string; // etiqueta bajo el total, ej. "Junio"
}
const { segments, total, caption = 'Junio' } = Astro.props;
const sum = segments.reduce((a, s) => a + s.value, 0) || 1;
let acc = 0;
const stops = segments
  .map((s) => {
    const from = (acc / sum) * 360;
    acc += s.value;
    const to = (acc / sum) * 360;
    return `${s.color} ${from.toFixed(1)}deg ${to.toFixed(1)}deg`;
  })
  .join(', ');
---

<div class="donut">
  <div
    class="donut__chart"
    style={`background: conic-gradient(${stops});`}
    role="img"
    aria-label={`Gastos por categoría, total ${total}`}
  >
    <div class="donut__hole">
      <span class="donut__total">{total}</span>
      <span class="donut__cap">{caption}</span>
    </div>
  </div>
  <ul class="donut__legend">
    {
      segments.map((s) => (
        <li>
          <span class="donut__dot" style={`background:${s.color}`} />
          <span class="donut__name">{s.emoji} {s.label}</span>
          <span class="donut__amt">{s.amount}</span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .donut {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    justify-content: flex-start;
    max-width: 460px;
  }
  .donut__chart {
    position: relative;
    flex-shrink: 0;
    width: 170px;
    height: 170px;
    border-radius: 50%;
  }
  .donut__hole {
    position: absolute;
    inset: 27px;
    border-radius: 50%;
    background: var(--bg-raised);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }
  .donut__total {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-h3, 1.35rem);
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .donut__cap {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .donut__legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 210px;
    flex: 1 1 210px;
  }
  .donut__legend li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-body);
    color: var(--text-secondary);
  }
  .donut__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .donut__name {
    flex: 1;
    white-space: nowrap;
  }
  .donut__amt {
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
    font-weight: var(--weight-medium);
  }
</style>
