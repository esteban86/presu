    fileInput.addEventListener('change', function(){ handleFiles(fileInput.files); fileInput.value=''; });

    function handleFiles(fileList){
      var files = Array.prototype.slice.call(fileList||[]);
      if(!files.length) return;
      var errEl = document.getElementById('upErr');
      var pending = 0, hadErr = false;
      function maybeAdvance(){ if(pending===0){ if(items.length){ editIdx=0; phase='edit'; render(); } } }
      files.forEach(function(f){
        if(f.type==='application/pdf' || /\.pdf$/i.test(f.name)){
          pending++; renderPdf(f).then(function(){ pending--; maybeAdvance(); }).catch(function(e){
            pending--; hadErr=true;
            var locked = e && (e.name==='PasswordException' || /password/i.test(String(e && e.message)));
            if(errEl) errEl.textContent = locked
              ? 'Para abrir ese PDF necesitas su clave. Si no la tienes a mano, sube un pantallazo del extracto.'
              : 'No pudimos abrir ese PDF (¿está dañado?). Prueba con un pantallazo.';
            maybeAdvance();
          });
        } else if(/^image\//.test(f.type) || /\.(png|jpe?g|webp|gif)$/i.test(f.name)){
          pending++; loadImage(f).then(function(){ pending--; maybeAdvance(); }).catch(function(){ pending--; hadErr=true; if(errEl) errEl.textContent='No pudimos abrir esa imagen.'; maybeAdvance(); });
        } else {
          if(errEl) errEl.textContent='Solo aceptamos imágenes o PDF.';
        }
      });
    }

    var MAXDIM = 2200; // downscale para memoria/rendimiento
    function fitCanvas(srcW, srcH){
      var scale = Math.min(1, MAXDIM/Math.max(srcW,srcH));
      var c = document.createElement('canvas');
      c.width = Math.round(srcW*scale); c.height = Math.round(srcH*scale);
      return c;
    }
    function loadImage(file){
      return new Promise(function(res,rej){
        var img = new Image();
        img.onload = function(){
          var c = fitCanvas(img.naturalWidth, img.naturalHeight);
          c.getContext('2d').drawImage(img,0,0,c.width,c.height);
          items.push({ canvas:c, boxes:[], textItems:[], source:'imagen', done:false, blob:null });
          URL.revokeObjectURL(img.src); res();
        };
        img.onerror = rej;
        img.src = URL.createObjectURL(file);
      });
    }
    function renderPdf(file){
      return file.arrayBuffer().then(function(buf){
        var task = pdfjsLib.getDocument({ data: buf });
        // PDF con clave (común en extractos): la pedimos aquí; NO se sube ni se guarda,
        // solo descifra localmente para poder rasterizarlo.
        task.onPassword = function(updatePassword, reason){
          var msg = reason === 2
            ? '🔒 Clave incorrecta. Escribe la clave del PDF (no se sube ni se guarda):'
            : '🔒 Este PDF tiene clave. Escríbela para abrirlo aquí mismo —no se sube ni se guarda, solo abre el documento en tu equipo:';
          var pw = window.prompt(msg);
          if (pw === null) { task.destroy(); } else { updatePassword(pw); }
        };
        return task.promise.then(function(pdf){
          var chain = Promise.resolve();
          var n = Math.min(pdf.numPages, 8); // tope de páginas
          for(var p=1;p<=n;p++){ (function(pg){
            chain = chain.then(function(){
              return pdf.getPage(pg).then(function(page){
                var vp1 = page.getViewport({scale:1});
                var scale = Math.min(2, MAXDIM/Math.max(vp1.width, vp1.height));
                var vp = page.getViewport({scale:scale});
                var c = document.createElement('canvas');
                c.width = Math.round(vp.width); c.height = Math.round(vp.height);
                return page.render({canvasContext:c.getContext('2d'), viewport:vp}).promise.then(function(){
                  return page.getTextContent().then(function(tc){
                    var tItems=[];
                    (tc.items||[]).forEach(function(t){
                      var s=(t.str||'').trim(); if(!s) return;
                      var m=pdfjsLib.Util.transform(vp.transform, t.transform);
                      var fh=Math.hypot(m[2],m[3]); var w=(t.width||0)*scale;
                      tItems.push({ str:s, x:m[4], y:m[5]-fh, w:Math.max(w, fh*0.4), h:fh*1.25 });
                    });
                    var item={ canvas:c, boxes:[], textItems:tItems, source:'pdf', done:false, blob:null };
                    // Auto-redacta lo sensible usando el texto real del PDF (cuenta, tarjeta, correo, nombre, dirección…)
                    var pad=Math.max(2, c.width/450);
                    tItems.forEach(function(t){ if(classifyPII(t.str)) item.boxes.push({ x:t.x-pad, y:t.y-pad, w:t.w+pad*2, h:t.h+pad*2 }); });
                    items.push(item);
                  });
                });
              });
            });
          })(p); }
          return chain;
        });
      });
    }

    // ── Editor de redacción ──
    var draw = null; // {startX,startY,box}
    function renderEdit(){
      var it = items[editIdx];
      setBar(35 + Math.round((editIdx/Math.max(items.length,1))*25));
      var multi = items.length>1 ? '<div class="pagehint">Documento '+(editIdx+1)+' de '+items.length+'</div>' : '';
      shell(
        BRAND+
        '<div class="eb">'+SHIELD+' Paso 2 de 3 · Tapa lo sensible</div>'+
        '<h1 class="q">Oculta tus datos</h1>'+
        '<p class="help">Pinta un rectángulo sobre lo que quieras <b>borrar</b>. Se elimina de verdad (no se puede recuperar).</p>'+
        '<div class="checklist"><div class="h"><svg viewBox="0 0 24 24"><path d="M12 9v4m0 4h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>Tapa esto</div>'+
          '<ul><li>Tu <b>nombre</b> y dirección</li><li><b>Número de cuenta</b> y de tarjeta</li><li><b>Saldo</b> / cupo disponible</li><li>Cédula, teléfono, correo, códigos QR</li></ul></div>'+
        '<p class="keepnote">Deja visible lo útil: <b>comercio, fecha, monto, moneda</b> de cada movimiento.</p>'+
        '<div class="editor-wrap"><div class="canvas-host"><canvas id="editCanvas"></canvas></div>'+
          '<div class="toolbar">'+
            '<button class="tool" id="ocrBtn"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 12h10"/></svg>Detectar datos sensibles</button>'+
            '<button class="tool" id="undoBtn" disabled><svg viewBox="0 0 24 24"><path d="M9 14 4 9l5-5"/><path d="M4 9h11a5 5 0 0 1 0 10h-1"/></svg>Deshacer</button>'+
            '<button class="tool" id="clearBtn" disabled><svg viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14"/></svg>Limpiar</button>'+
          '</div>'+
          multi+
        '</div>'+
        '<div class="nav"><button class="btn btn-mint" id="nextBtn">'+(editIdx<items.length-1?'Listo, siguiente':'Listo, continuar')+' <span style="font-size:1.1em">→</span></button>'+
          '<button class="skip" id="skipDoc">Quitar este documento</button></div>'+
        '<p class="err" id="editErr"></p>'
      );
      setupCanvas(it);
      document.getElementById('ocrBtn').addEventListener('click', function(){ runOCR(it, this); });
      document.getElementById('undoBtn').addEventListener('click', function(){ it.boxes.pop(); paintEditor(it); });
      document.getElementById('clearBtn').addEventListener('click', function(){ it.boxes=[]; paintEditor(it); });
      document.getElementById('nextBtn').addEventListener('click', function(){ finalizeItem(it); if(editIdx<items.length-1){ editIdx++; render(); } else { phase='form'; render(); } });
      document.getElementById('skipDoc').addEventListener('click', function(){
        items.splice(editIdx,1);
        if(!items.length){ phase='upload'; render(); return; }
        if(editIdx>=items.length) editIdx=items.length-1;
        render();
      });
      // Auto-OCR: si la página no trae capa de texto (imagen o PDF rasterizado), la analiza sola
      // (no bloquea: puedes tapar a mano mientras corre; las marcas aparecen al terminar).
      if(!(it.textItems && it.textItems.length) && !it.ocrTried){ runOCR(it, document.getElementById('ocrBtn'), true); }
    }

    var cv, cctx, viewScale;
    function setupCanvas(it){
      cv = document.getElementById('editCanvas');
      cctx = cv.getContext('2d');
      cv.width = it.canvas.width; cv.height = it.canvas.height;
      paintEditor(it);
      var rectOf = function(){ return cv.getBoundingClientRect(); };
      var toSrc = function(e){ var r=rectOf(); var sx=cv.width/r.width, sy=cv.height/r.height; return { x:(e.clientX-r.left)*sx, y:(e.clientY-r.top)*sy }; };
      cv.addEventListener('pointerdown', function(e){ e.preventDefault(); cv.setPointerCapture(e.pointerId); var p=toSrc(e); draw={x0:p.x,y0:p.y,box:{x:p.x,y:p.y,w:0,h:0}}; });
      cv.addEventListener('pointermove', function(e){ if(!draw) return; var p=toSrc(e); draw.box={ x:Math.min(draw.x0,p.x), y:Math.min(draw.y0,p.y), w:Math.abs(p.x-draw.x0), h:Math.abs(p.y-draw.y0) }; paintEditor(it, draw.box); });
      cv.addEventListener('pointerup', function(e){ if(!draw) return; var b=draw.box; draw=null; if(b.w>6 && b.h>6){ it.boxes.push(b); } paintEditor(it); });
      cv.addEventListener('pointercancel', function(){ draw=null; paintEditor(it); });
    }
    function paintEditor(it, preview){
      cctx.drawImage(it.canvas,0,0);
      var all = it.boxes.concat(preview?[preview]:[]);
      for(var i=0;i<all.length;i++){ var b=all[i];
        cctx.fillStyle='rgba(0,0,0,.78)'; cctx.fillRect(b.x,b.y,b.w,b.h);
        cctx.strokeStyle='#FB7185'; cctx.lineWidth=Math.max(2, cv.width/500); cctx.strokeRect(b.x,b.y,b.w,b.h);
      }
      var undo=document.getElementById('undoBtn'), clr=document.getElementById('clearBtn');
      if(undo) undo.disabled = !it.boxes.length;
      if(clr) clr.disabled = !it.boxes.length;
    }

    // ── OCR opcional (Tesseract.js, lazy) ──
    var tesseractLoading = null;
    function loadTesseract(){
      if(window.Tesseract) return Promise.resolve();
      if(tesseractLoading) return tesseractLoading;
      tesseractLoading = new Promise(function(res,rej){
        var s=document.createElement('script');
        s.src='https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js';
        s.onload=res; s.onerror=rej; document.head.appendChild(s);
      });
      return tesseractLoading;
    }
    function luhn(num){ var s=0,alt=false; for(var i=num.length-1;i>=0;i--){ var d=+num[i]; if(alt){ d*=2; if(d>9)d-=9; } s+=d; alt=!alt; } return s%10===0; }
    // Palabras típicas de un extracto (NO son nombres) — evita auto-tapar encabezados útiles.
    var KEEP_WORDS=/\b(extracto|tarjeta|credito|crédito|debito|débito|cuenta|saldo|pago|pagos|periodo|período|fecha|detalle|transacci|movimiento|interes|interés|cupo|total|minimo|mínimo|banco|estado|consumo|cuota|tasa|valor|capital|mora|abono|resumen|disponible|facturado|cobranza|gastos|nombre|titular|direccion|dirección|correo)\b/i;
    function classifyPII(t){
      var s=(t||'').trim(); if(!s) return false;
      if(/\d{1,4}[-/.]\d{1,2}[-/.]\d{1,4}/.test(s)) return false;   // fecha → conservar
      if(/^[-$]?[\d.,\s]+$/.test(s) && s.replace(/\D/g,'').length<=7) return false; // monto corto → conservar
      if(/[\w.+-]+@[\w-]+\.[\w.]+/.test(s)) return true;            // correo
      var digits=s.replace(/\D/g,'');
      if(digits.length>=13 && digits.length<=19 && luhn(digits)) return true; // tarjeta
      if(digits.length>=9) return true;                             // cuenta / cédula / teléfono largo
      if(/\b(calle|carrera|cra|cll|kr|av|avenida|diagonal|transversal|manzana|apto|apartamento|barrio)\b/i.test(s) && /\d/.test(s)) return true; // dirección
      // Nombre en MAYÚSCULAS (2-4 palabras, solo letras) que no sea texto típico de extracto
      var words=s.split(/\s+/);
      if(words.length>=2 && words.length<=4 && /^[A-ZÁÉÍÓÚÑ ]+$/.test(s) && s.replace(/\s/g,'').length>=6 && !KEEP_WORDS.test(s)) return true;
      return false;
    }
    function rectsOverlap(a,b){ return !(a.x+a.w<b.x || b.x+b.w<a.x || a.y+a.h<b.y || b.y+b.h<a.y); }
    function textNotRedacted(it){ return (it.textItems||[]).filter(function(t){ for(var i=0;i<it.boxes.length;i++){ if(rectsOverlap(it.boxes[i],t)) return false; } return true; }); }
    // Texto anónimo (estructurado) para entrenar el parser: lo que NO quedó tapado.
    function extractAnonText(it){ return textNotRedacted(it).map(function(t){return t.str;}).join(' ').replace(/\s+/g,' ').trim().slice(0,60000); }
    // ¿Quedó PII sin tapar? (red de seguridad antes de enviar)
    function remainingHasPII(it){ return textNotRedacted(it).some(function(t){ return classifyPII(t.str); }); }
    // Tokens con posición (x,y,w,h) para que el parser entienda columnas/filas. Solo lo NO tapado.
    function tokensOf(it){
      return {
        w: it.canvas.width, h: it.canvas.height, source: it.source || 'imagen',
        tokens: textNotRedacted(it).map(function(t){
          return { t:t.str, x:Math.round(t.x), y:Math.round(t.y), w:Math.round(t.w), h:Math.round(t.h) };
        }).slice(0, 4000)
      };
    }
    function runOCR(it, btn, auto){
      it.ocrTried = true;
      var errEl=document.getElementById('editErr'); if(errEl) errEl.textContent = auto ? 'Esta página es una imagen — la analizamos sola para marcar tus datos…' : '';
      btn.classList.add('busy'); var orig=btn.innerHTML; btn.innerHTML='Analizando…';
      loadTesseract().then(function(){
        return Tesseract.recognize(it.canvas, 'spa+eng');
      }).then(function(res){
        var words=(res && res.data && res.data.words)||[]; var added=0;
        var fillText = !(it.textItems && it.textItems.length); // solo guardamos texto OCR si no vino del PDF
        words.forEach(function(w){
          if(w.confidence<35) return;
          var b=w.bbox;
          if(fillText) it.textItems.push({ str:w.text, x:b.x0, y:b.y0, w:b.x1-b.x0, h:b.y1-b.y0 });
          if(classifyPII(w.text)){
            var pad=Math.max(2, it.canvas.width/400);
            it.boxes.push({ x:b.x0-pad, y:b.y0-pad, w:(b.x1-b.x0)+pad*2, h:(b.y1-b.y0)+pad*2 });
            added++;
          }
        });
        paintEditor(it);
        btn.classList.remove('busy'); btn.innerHTML=orig;
        if(errEl) errEl.textContent = added? ('Marcamos '+added+' posible(s) dato(s). Revísalos y agrega lo que falte.') : 'No detectamos datos automáticamente. Tápalos a mano.';
      }).catch(function(){
        btn.classList.remove('busy'); btn.innerHTML=orig;
        if(errEl) errEl.textContent='No pudimos analizar automáticamente. Tapa los datos a mano.';
      });
    }

    // Aplana destructivamente las cajas sobre el canvas y exporta JPEG
    function finalizeItem(it){
      var ctx=it.canvas.getContext('2d');
      ctx.fillStyle='#000';
      it.boxes.forEach(function(b){ ctx.fillRect(Math.round(b.x),Math.round(b.y),Math.round(b.w),Math.round(b.h)); });
      it.done=true;
    }
    function exportItem(it){ return new Promise(function(res){ it.canvas.toBlob(function(blob){ it.blob=blob; res(blob); },'image/jpeg',0.82); }); }

    // ── Formulario de metadatos ──
    function renderForm(){
      setBar(78);
      var co = COUNTRIES;
      var cOpts = co.map(function(c){ return '<option value="'+c.code+'"'+(c.code===meta.pais?' selected':'')+'>'+esc(c.name)+'</option>'; }).join('');
      shell(
        BRAND+
        '<div class="eb">'+SHIELD+' Paso 3 de 3 · Datos</div>'+
        '<h1 class="q">¿De qué banco es?</h1>'+
        '<p class="help">Esto nos dice qué formato estamos aprendiendo. Nada de esto te identifica.</p>'+
        '<div class="grid2">'+
          '<div class="frow"><label class="field-label">País</label><select class="field2" id="fPais">'+cOpts+'</select></div>'+
          '<div class="frow"><label class="field-label">Moneda</label><input class="field2" id="fMoneda" value="'+esc(meta.moneda)+'" placeholder="COP"></div>'+
