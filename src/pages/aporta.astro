---
import StaticPage from '../layouts/StaticPage.astro';
---
<StaticPage
  title="Ayuda a que Presu lea tu banco — aporta un documento anónimo"
  description="Comparte un extracto o pantallazo de transacción 100% anonimizado en tu propio navegador. El original nunca sale de tu equipo. Ayúdanos a que Presu entienda tu banco."
  ogTitle="Ayuda a que Presu lea tu banco 🌱"
  ogDescription="Aporta un documento financiero anonimizado en tu propio equipo. El original nunca sale de tu dispositivo. Tu plata, clara."
>
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

  <header class="site-header">
    <div class="sh-wrap">
      <div class="sh-brand">
        <a class="sh-logo" href="/" aria-label="Presu — inicio"><span class="wordmark"><span class="wm-bar" aria-hidden="true"></span><span class="wm-text">presu</span></span></a>
        <a class="sh-endorse" href="https://asimetrica.co" target="_blank" rel="noopener"><span>de</span><img src="/asimetrica-logo.webp" alt="Asimétrica" /></a>
      </div>
      <nav class="sh-nav" id="sh-nav">
        <a href="/#como">Cómo</a>
        <a href="/#privacidad">Privacidad</a>
        <a href="/#planes">Planes</a>
        <a href="/aporta">Aporta 🌱</a>
      </nav>
      <div class="sh-actions"><a class="sh-cta" href="/#waitlist">Únete a la lista</a><button class="sh-burger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="sh-nav"><span></span><span></span><span></span></button></div>
    </div>
  </header>
  <div class="progress"><i id="bar"></i></div>
  <button class="back" id="backBtn" aria-label="Atrás">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    Atrás
  </button>
  <div class="conf" id="conf" aria-hidden="true"></div>
  <input type="file" id="fileInput" accept="image/*,application/pdf" multiple hidden />

  <div class="stage"><div class="step" id="step"></div></div>

  <style is:global>
    :root{
      --mint:#34D399;--mint-bright:#5EEAB8;--ink:#08231A;--tx:#F4F4F3;--mut:#A1A1A6;--mut2:#6B6B72;
      --bg:#08080A;--bg2:#101014;--bg3:#16161A;--line:rgba(255,255,255,.1);--line2:rgba(255,255,255,.16);
      --red:#FB7185;--amber:#FBBF24;
      --head:"Space Grotesk",sans-serif;--mono:"JetBrains Mono",monospace
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;background:var(--bg);color:var(--tx);font-family:"Hanken Grotesk",sans-serif;
      line-height:1.5;-webkit-font-smoothing:antialiased;
      background-image:radial-gradient(120% 80% at 50% -10%,rgba(52,211,153,.10),transparent 60%);
      background-attachment:fixed;
    }
    .progress{position:fixed;top:0;left:0;right:0;height:4px;background:rgba(255,255,255,.06);z-index:50}
    .progress > i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--mint),var(--mint-bright));
      border-radius:0 4px 4px 0;transition:width .5s cubic-bezier(.2,.7,.2,1)}
    .back{position:fixed;top:18px;left:18px;z-index:40;display:none;align-items:center;gap:6px;
      background:rgba(255,255,255,.05);border:1px solid var(--line);color:var(--mut);
      border-radius:999px;padding:8px 14px 8px 11px;font-size:.85rem;font-family:inherit;cursor:pointer;transition:.18s}
    .back:hover{color:var(--tx);border-color:var(--line2);background:rgba(255,255,255,.08)}
    .back svg{width:14px;height:14px}

    .stage{min-height:100dvh;display:grid;place-items:center;padding:60px 20px}
    .step{width:100%;max-width:600px;margin:0 auto}
    .step.anim{animation:stepIn .45s cubic-bezier(.2,.7,.2,1) both}
    @keyframes stepIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
    .wide{max-width:920px}

    .brand{display:inline-flex;margin-bottom:26px}
    .wordmark{position:relative;display:inline-flex;align-items:center;line-height:.9}
    .wm-text{position:relative;z-index:1;font-family:var(--head);font-weight:700;font-size:1.55rem;letter-spacing:-.05em;color:var(--tx);line-height:.9}
    .wm-bar{position:absolute;left:-5%;right:-8%;top:53%;height:.36em;border-radius:999px;background:var(--mint);transform:rotate(-9deg);z-index:0}
    /* Site header (igual al resto del sitio) */
    .site-header{position:sticky;top:0;z-index:100;background:rgba(8,8,10,.72);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--line)}
    .sh-wrap{max-width:1200px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px}
    .sh-brand{display:flex;align-items:center;gap:12px;min-width:0}
    .sh-logo{display:inline-flex;text-decoration:none}
    .sh-logo .wm-text{font-size:1.375rem}
    .sh-endorse{display:inline-flex;align-items:center;gap:7px;padding-left:12px;border-left:1px solid var(--line);font-family:"Hanken Grotesk",sans-serif;font-size:.8rem;font-weight:500;color:var(--mut2);text-decoration:none;white-space:nowrap}
    .sh-endorse img{height:.95rem;width:auto;display:block}
    .sh-nav{display:flex;align-items:center;gap:26px}
    .sh-nav a{font-family:"Hanken Grotesk",sans-serif;font-size:1rem;font-weight:500;color:var(--mut);text-decoration:none;transition:color .16s}
    .sh-nav a:hover{color:var(--tx)}
    .sh-cta{display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:9px 20px;border-radius:999px;background:var(--mint);color:#06231A;font-family:"Hanken Grotesk",sans-serif;font-weight:700;font-size:.9rem;text-decoration:none;white-space:nowrap;transition:background .16s}
    .sh-cta:hover{background:var(--mint-bright)}
    .sh-actions{display:flex;align-items:center;gap:10px}
  .sh-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:42px;height:42px;padding:0;background:none;border:1px solid var(--line);border-radius:11px;cursor:pointer}
  .sh-burger span{display:block;width:20px;height:2px;margin:0 auto;background:var(--tx);border-radius:2px;transition:transform .22s,opacity .22s}
  .sh-burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .sh-burger[aria-expanded="true"] span:nth-child(2){opacity:0}
  .sh-burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  @media(max-width:640px){
    .sh-endorse{display:none}
    .sh-burger{display:flex}
    .sh-wrap{padding:12px 16px}
    .sh-nav{position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:stretch;gap:0;padding:6px 16px 14px;background:var(--bg);border-bottom:1px solid var(--line);display:none}
    .site-header.is-open .sh-nav{display:flex}
    .sh-nav a{padding:14px 4px;font-size:1.05rem;border-bottom:1px solid var(--line)}
    .sh-nav a:last-child{border-bottom:0}
  }

    .eb{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--mint);margin-bottom:14px;display:flex;align-items:center;gap:8px}
    .q{font-family:var(--head);font-weight:700;font-size:clamp(1.55rem,4.2vw,2.2rem);line-height:1.12;letter-spacing:-.02em;color:#fff;margin:0 0 10px}
    .lead{font-size:1.06rem;line-height:1.6;color:#D4D4D6;margin:0 0 16px}
    .lead b{color:#fff}
    .help{color:var(--mut);font-size:1rem;margin:0 0 22px}
    .center{text-align:center}

    /* Sellos de privacidad */
    .seals{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 22px}
    .seal{display:inline-flex;align-items:center;gap:7px;background:rgba(52,211,153,.08);
      border:1px solid rgba(52,211,153,.35);color:var(--mint-bright);border-radius:999px;
      padding:7px 13px;font-size:.82rem;font-weight:600}
    .seal svg{width:14px;height:14px;stroke:var(--mint);fill:none;stroke-width:2.2}

    /* Pasos numerados */
    .steps3{display:grid;gap:12px;margin:0 0 24px}
    .s3{display:flex;gap:13px;align-items:flex-start;background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:14px 16px}
    .s3 .n{flex:none;width:26px;height:26px;border-radius:8px;background:rgba(52,211,153,.14);color:var(--mint);
      display:grid;place-items:center;font-family:var(--mono);font-weight:600;font-size:.85rem}
    .s3 b{color:#fff}.s3 span{color:var(--mut);font-size:.95rem}

    /* Barra colectiva */
    .collective{background:var(--bg2);border:1px solid var(--line);border-radius:16px;padding:16px 18px;margin:0 0 22px}
    .collective .top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px}
    .collective .big{font-family:var(--head);font-weight:700;font-size:1.5rem;color:#fff}
    .collective .lab{font-size:.82rem;color:var(--mut2);font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em}
    .cbar{height:9px;border-radius:999px;background:rgba(255,255,255,.07);overflow:hidden}
    .cbar > i{display:block;height:100%;background:linear-gradient(90deg,var(--mint),var(--mint-bright));width:0;transition:width .8s cubic-bezier(.2,.7,.2,1)}

    /* Dropzone */
    .drop{border:2px dashed var(--line2);border-radius:18px;background:var(--bg2);padding:38px 22px;text-align:center;
      transition:.18s;cursor:pointer}
    .drop:hover,.drop.over{border-color:var(--mint);background:rgba(52,211,153,.06)}
    .drop .ic{width:54px;height:54px;margin:0 auto 14px;border-radius:14px;background:rgba(52,211,153,.12);
      display:grid;place-items:center}
    .drop .ic svg{width:26px;height:26px;stroke:var(--mint);fill:none;stroke-width:2}
    .drop h3{margin:0 0 6px;font-family:var(--head);font-weight:600;font-size:1.15rem;color:#fff}
    .drop p{margin:0;color:var(--mut);font-size:.92rem}
    .types{margin-top:14px;font-size:.8rem;color:var(--mut2);font-family:var(--mono)}

    /* Editor de redacción */
    .editor-wrap{background:var(--bg2);border:1px solid var(--line);border-radius:16px;padding:12px;margin:0 0 14px}
    .canvas-host{position:relative;display:flex;justify-content:center;background:#000;border-radius:10px;overflow:auto;max-height:62vh}
    #editCanvas{display:block;max-width:100%;height:auto;touch-action:none;cursor:crosshair}
    .toolbar{display:flex;flex-wrap:wrap;gap:9px;margin-top:12px}
    .tool{display:inline-flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--line2);
      color:var(--tx);border-radius:11px;padding:10px 14px;font-family:inherit;font-size:.92rem;font-weight:600;cursor:pointer;transition:.16s}
    .tool:hover{border-color:var(--mint);background:rgba(52,211,153,.08)}
    .tool:disabled{opacity:.45;cursor:not-allowed}
    .tool svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2}
    .tool.busy{pointer-events:none;opacity:.7}
    .pagehint{font-size:.84rem;color:var(--mut2);margin:10px 2px 0}

    /* Checklist */
    .checklist{background:rgba(251,113,133,.06);border:1px solid rgba(251,113,133,.3);border-radius:13px;padding:13px 15px;margin:0 0 14px}
    .checklist .h{font-weight:700;color:#fff;font-size:.95rem;margin-bottom:7px;display:flex;align-items:center;gap:8px}
    .checklist .h svg{width:16px;height:16px;stroke:var(--red);fill:none;stroke-width:2.2}
    .checklist ul{margin:0;padding-left:18px;color:#E7B7BF;font-size:.9rem;line-height:1.65}
    .keepnote{font-size:.86rem;color:var(--mut);margin:0 0 6px}
    .keepnote b{color:var(--mint-bright)}

    /* Formulario */
    .field-label{display:block;font-size:.82rem;color:var(--mut);margin:0 0 7px;font-weight:600}
    .field2{width:100%;background:var(--bg2);border:1.5px solid var(--line);border-radius:12px;color:#fff;font-family:inherit;font-size:1rem;padding:13px 14px;outline:none;transition:.16s}
    .field2::placeholder{color:var(--mut2)}
    .field2:focus{border-color:var(--mint);background:var(--bg3)}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .frow{margin:0 0 16px}
    select.field2{appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%23A1A1A6' stroke-width='2'><path d='M4 6l4 4 4-4'/></svg>");background-repeat:no-repeat;background-position:right 14px center}
    .checkrow{display:flex;gap:11px;align-items:flex-start;margin:6px 0 0;font-size:.92rem;color:var(--mut)}
    .checkrow input{margin-top:3px;accent-color:var(--mint);width:18px;height:18px;flex:none}
    .checkrow a{color:var(--mint-bright)}

    /* Botones */
    .nav{display:flex;align-items:center;gap:12px;margin-top:22px;flex-wrap:wrap}
    .btn{border:0;border-radius:13px;padding:14px 24px;font-weight:700;font-size:1rem;cursor:pointer;font-family:inherit;
      display:inline-flex;align-items:center;gap:9px;transition:.16s;text-decoration:none}
    .btn-mint{background:var(--mint);color:var(--ink)}
    .btn-mint:hover{background:var(--mint-bright);transform:translateY(-2px)}
    .btn-mint:disabled{background:#1d3a30;color:#5a6b63;cursor:not-allowed;transform:none}
    .btn-ghost{background:rgba(255,255,255,.05);border:1px solid var(--line2);color:#fff}
    .btn-ghost:hover{background:rgba(255,255,255,.09)}
    .btn-wa{background:#25D366;color:#06351d}
    .btn-wa:hover{background:#3ee07a;transform:translateY(-2px)}
    .skip{background:none;border:0;color:var(--mut2);font-size:.92rem;cursor:pointer;font-family:inherit;text-decoration:underline;text-underline-offset:3px}
    .skip:hover{color:var(--mut)}
    .consent2{font-size:.82rem;color:var(--mut2);margin:18px 0 0;line-height:1.5}
    .err{color:#FCA5A5;font-size:.92rem;margin-top:12px;min-height:1em}

    /* Final */
    .check{width:84px;height:84px;margin:0 auto 22px;border-radius:50%;background:rgba(52,211,153,.12);
      border:1.5px solid rgba(52,211,153,.5);display:grid;place-items:center}
    .check svg{width:42px;height:42px;stroke:var(--mint);fill:none;stroke-width:3.5;stroke-linecap:round;stroke-linejoin:round}
    .conf{position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:5}
    .conf i{position:absolute;top:-12px;width:9px;height:9px;border-radius:2px;opacity:.9;animation:fall linear forwards}
    @keyframes fall{to{transform:translateY(105dvh) rotate(540deg);opacity:0}}

    .thumbs{display:flex;gap:8px;flex-wrap:wrap;margin:14px 0 0}
    .thumb{position:relative;width:64px;height:64px;border-radius:9px;overflow:hidden;border:1px solid var(--line2);background:#000}
    .thumb img{width:100%;height:100%;object-fit:cover}
    .thumb .rm{position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:rgba(0,0,0,.7);color:#fff;border:0;cursor:pointer;font-size:12px;line-height:1;display:grid;place-items:center}

    @media (max-width:520px){ .grid2{grid-template-columns:1fr} }
    @media (prefers-reduced-motion:reduce){ .step.anim,.conf i{animation:none!important} }
  </style>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script is:inline>
  (function(){
    'use strict';
    var API = ['presu.asimetrica.co','presu.io','www.presu.io','presu.com.co'].indexOf(location.hostname) !== -1
      ? 'https://presu-waitlist.asimetrica.workers.dev'
      : 'https://presu-waitlist-staging.asimetrica.workers.dev';
    var SITE = 'https://presu.io';
    var GOAL = 500; // meta de documentos para la barra colectiva

    // pdf.js worker
    if(window.pdfjsLib){ pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; }

    // ── Países → bancos → moneda (LATAM; CO por defecto) ──
    var COUNTRIES = [
      { code:'CO', name:'Colombia', cur:'COP', banks:['Bancolombia','Nu','Nequi','Daviplata','Davivienda','Banco de Bogotá','BBVA','Banco de Occidente','Scotiabank Colpatria','Banco Caja Social','Banco Popular','Banco Falabella','AV Villas','Lulo Bank','RappiPay (Rappicard)','Ualá','Movii','Bancoomeva'] },
      { code:'MX', name:'México', cur:'MXN', banks:['BBVA México','Banorte','Santander','Banamex','HSBC','Scotiabank','Nu','Hey Banco','Klar','Mercado Pago'] },
      { code:'AR', name:'Argentina', cur:'ARS', banks:['Banco Nación','Banco Galicia','Santander','BBVA','Banco Macro','Brubank','Ualá','Mercado Pago','Naranja X'] },
      { code:'CL', name:'Chile', cur:'CLP', banks:['Banco de Chile','BancoEstado','Santander','BCI','Scotiabank','Banco Falabella','Mercado Pago','Tenpo'] },
      { code:'PE', name:'Perú', cur:'PEN', banks:['BCP','BBVA','Interbank','Scotiabank','Yape','Plin','Banco de la Nación'] },
      { code:'EC', name:'Ecuador', cur:'USD', banks:['Banco Pichincha','Banco Guayaquil','Produbanco','Banco del Pacífico','Banco Bolivariano'] },
      { code:'US', name:'Estados Unidos', cur:'USD', banks:['Bank of America','Chase','Wells Fargo','Citi','Capital One'] },
      { code:'XX', name:'Otro país', cur:'', banks:[] }
    ];

    // ── Estado ──
    var phase = 'intro';     // intro | upload | edit | form | sending | done
    var items = [];          // { canvas:<full-res>, boxes:[{x,y,w,h}], done:false, blob:null }
    var editIdx = 0;
    var progress = null;     // { total, goal, banks }
    var meta = { pais:'CO', banco:'', moneda:'COP', tipo:'', nombre:'', correo:'', codigo:'' };

    var stepEl = document.getElementById('step');
    var barEl = document.getElementById('bar');
    var backEl = document.getElementById('backBtn');
    var confEl = document.getElementById('conf');
    var fileInput = document.getElementById('fileInput');

    function esc(s){return String(s==null?'':s).replace(/[&<>"]/g,function(c){return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c];});}
    function setBar(p){ barEl.style.width = Math.max(0,Math.min(100,p))+'%'; }
    function shell(html){ stepEl.className='step anim'; if(phase==='edit') stepEl.classList.add('wide'); stepEl.innerHTML=html; void stepEl.offsetWidth; }
    var BRAND = '';  /* el logo ahora vive en el site-header fijo, no en cada paso */
    var SHIELD = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex:none;vertical-align:middle"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';

    // ── Arranque ──
    function boot(){
      // Evita que soltar el archivo fuera de la zona haga que el navegador lo abra/descargue.
      ['dragover','drop'].forEach(function(ev){ window.addEventListener(ev, function(e){ e.preventDefault(); }, false); });
      render(); loadProgress();
    }
    function loadProgress(){
      fetch(API+'/contrib/progress',{cache:'no-store'}).then(function(r){return r.json();})
        .then(function(d){ if(d && typeof d.total==='number'){ progress=d; if(phase==='intro') renderIntro(); } })
        .catch(function(){});
    }

    function render(){
      backEl.style.display = (phase==='upload'||phase==='edit'||phase==='form') ? 'inline-flex' : 'none';
      if(phase==='intro') return renderIntro();
      if(phase==='upload') return renderUpload();
      if(phase==='edit') return renderEdit();
      if(phase==='form') return renderForm();
      if(phase==='sending') return renderSending();
      if(phase==='done') return renderDone();
    }

    // ── Intro ──
    function renderIntro(){
      setBar(6);
      var total = progress ? progress.total : null;
      var banks = progress ? (progress.banks ? progress.banks.length : 0) : null;
      var pct = total!=null ? Math.min(100, Math.round(total/GOAL*100)) : 0;
      var collective = total!=null ? (
        '<div class="collective">'+
        '<div class="top"><span class="big">'+total+' <span style="font-size:1rem;color:var(--mut)">de '+GOAL+'</span></span>'+
        '<span class="lab">'+(banks||0)+' bancos</span></div>'+
        '<div class="cbar"><i style="width:'+pct+'%"></i></div></div>'
      ) : '';
      shell(
        BRAND+
        '<div class="eb">'+SHIELD+' Aporte anónimo</div>'+
        '<h1 class="q">Ayúdanos a que Presu <span style="color:var(--mint)">lea tu banco</span></h1>'+
        '<p class="lead">Presu aprende a leer cada banco con ejemplos reales. Comparte un <b>extracto</b> o un <b>pantallazo de una transacción</b> — y nos ayudas a que funcione con el tuyo.</p>'+
        '<div class="seals">'+
          '<span class="seal">'+SHIELD+' Se anonimiza en tu equipo</span>'+
          '<span class="seal">'+SHIELD+' El original nunca se sube</span>'+
          '<span class="seal">'+SHIELD+' Sin cuenta · sin claves</span>'+
        '</div>'+
        collective+
        '<div class="steps3">'+
          '<div class="s3"><span class="n">1</span><div><b>Sube</b> <span>— un PDF o pantallazo (se procesa solo en tu navegador).</span></div></div>'+
          '<div class="s3"><span class="n">2</span><div><b>Tapa lo sensible</b> <span>— te ayudamos a ocultar nombre, cuenta y saldo. Se borra de verdad.</span></div></div>'+
          '<div class="s3"><span class="n">3</span><div><b>Aporta</b> <span>— solo viaja la imagen ya tapada. Nada más.</span></div></div>'+
        '</div>'+
        '<div class="nav"><button class="btn btn-mint" id="go">Empezar <span style="font-size:1.1em">→</span></button></div>'+
