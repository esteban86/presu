        '<details style="margin:4px 0 8px"><summary style="cursor:pointer;color:var(--mut);font-size:.92rem">¿Quieres crédito por tu aporte? (opcional)</summary>'+
          '<div class="frow" style="margin-top:12px"><input class="field2" id="fNombre" placeholder="Tu nombre (aparece en el Muro)" value="'+esc(meta.nombre)+'"></div>'+
          '<div class="frow"><input class="field2" id="fCorreo" placeholder="Correo o código de Fundador" value="'+esc(meta.correo)+'"></div>'+
        '</details>'+
        '<label class="checkrow"><input type="checkbox" id="fConsent"><span>Confirmo que <b style="color:#fff">tapé mis datos personales</b> y autorizo usar esta imagen anónima para mejorar Presu. <a href="/privacidad">Privacidad</a>.</span></label>'+
        '<div class="thumbs" id="thumbs"></div>'+
        '<div class="nav"><button class="btn btn-mint" id="sendBtn" disabled>Aportar '+items.length+' documento'+(items.length>1?'s':'')+' <span style="font-size:1.1em">→</span></button></div>'+
        '<p class="err" id="formErr"></p>'+
        '<p class="consent2">'+SHIELD+' Solo viaja la imagen que ya tapaste. El original nunca sale de tu equipo.</p>'
      );
      var sel=document.getElementById('fPais');
      function syncCountry(){
        var c = COUNTRIES.filter(function(x){return x.code===sel.value;})[0]||COUNTRIES[0];
        meta.pais=c.code;
        document.getElementById('bankList').innerHTML = c.banks.map(function(b){return '<option value="'+esc(b)+'">';}).join('');
        var mon=document.getElementById('fMoneda'); if(!mon.value || mon.dataset.auto!=='0'){ mon.value=c.cur; mon.dataset.auto='1'; }
      }
      sel.addEventListener('change', syncCountry); syncCountry();
      document.getElementById('fMoneda').addEventListener('input', function(){ this.dataset.auto='0'; });
      renderThumbs();
      var consent=document.getElementById('fConsent'), sendBtn=document.getElementById('sendBtn');
      consent.addEventListener('change', function(){ sendBtn.disabled = !consent.checked; });
      sendBtn.addEventListener('click', submitAll);
    }
    function renderThumbs(){
      var host=document.getElementById('thumbs'); if(!host) return; host.innerHTML='';
      items.forEach(function(it,i){
        var url = it.canvas.toDataURL('image/jpeg',0.5);
        var d=document.createElement('div'); d.className='thumb';
        d.innerHTML='<img src="'+url+'"><button class="rm" title="Quitar">×</button>';
        d.querySelector('.rm').addEventListener('click', function(){ items.splice(i,1); if(!items.length){ phase='upload'; render(); } else renderForm(); });
        host.appendChild(d);
      });
    }

    function submitAll(){
      var errEl=document.getElementById('formErr'); errEl.textContent='';
      meta.banco=(document.getElementById('fBanco').value||'').trim();
      meta.moneda=(document.getElementById('fMoneda').value||'').trim();
      meta.tipo=document.getElementById('fTipo').value;
      var nombre=(document.getElementById('fNombre')||{}).value||'';
      var correo=(document.getElementById('fCorreo')||{}).value||'';
      if(!meta.banco){ errEl.textContent='Dinos de qué banco es.'; return; }
      if(!meta.tipo){ errEl.textContent='Elige el tipo de documento.'; return; }
      meta.nombre=nombre.trim(); meta.correo=correo.trim();
      // Red de seguridad: si parece que quedó un dato personal sin tapar, avisa antes de enviar.
      if(items.some(remainingHasPII)){
        if(!window.confirm('⚠️ Parece que quedó algún dato personal sin tapar (tu nombre, número de cuenta o dirección). Revísalo antes de enviar.\n\n¿Enviar de todas formas?')) return;
      }
      phase='sending'; render();
      // Exporta todos los blobs (aplanados) y envía
      Promise.all(items.map(exportItem)).then(function(){
        var sid = (window.crypto && crypto.randomUUID) ? crypto.randomUUID() : (''+Date.now()+'-'+Math.round(Math.random()*1e9));
        var fd=new FormData();
        fd.append('pais',meta.pais); fd.append('banco',meta.banco); fd.append('moneda',meta.moneda);
        fd.append('tipo',meta.tipo); fd.append('nombre',meta.nombre); fd.append('ref',meta.correo);
        fd.append('botcheck',''); fd.append('n',String(items.length)); fd.append('sid',sid);
        items.forEach(function(it,i){ fd.append('doc'+i, it.blob, 'doc'+i+'.jpg'); fd.append('tokens'+i, JSON.stringify(tokensOf(it))); });
        return fetch(API+'/contrib',{method:'POST',body:fd});
      }).then(function(r){ return r.json().catch(function(){return {};}); })
        .then(function(d){ if(d && (d.status==='ok')){ if(d.progress) progress=d.progress; phase='done'; render(); } else { failSend(d && d.reason); } })
        .catch(function(){ failSend('network'); });
    }
    function failSend(reason){
      phase='form'; render();
      var errEl=document.getElementById('formErr');
      if(errEl) errEl.textContent = reason==='too_big' ? 'Alguna imagen pesa demasiado. Intenta con menos páginas.' : 'No pudimos enviar. Revisa tu conexión e inténtalo de nuevo.';
    }

    function renderSending(){
      setBar(92); backEl.style.display='none';
      shell(BRAND+'<div class="center" style="padding:30px 0;color:var(--mut)"><div class="q" style="font-size:1.4rem;color:#fff">Anonimizando y enviando…</div><p class="lead" style="margin-top:10px">Aplanando las imágenes y subiendo solo lo que tapaste.</p></div>');
    }

    // ── Final + compartir ──
    function renderDone(){
      setBar(100); backEl.style.display='none'; confetti();
      var total = progress ? progress.total : null;
      var waText = encodeURIComponent('Le aporté un documento anónimo a Presu para que aprenda a leer mi banco 🌱 El original nunca sale de tu equipo — ayuda tú también: '+SITE+'/aporta');
      var prog = total!=null ? '<div class="collective" style="margin-top:6px"><div class="top"><span class="big">'+total+'</span><span class="lab">documentos aportados</span></div><div class="cbar"><i style="width:'+Math.min(100,Math.round(total/GOAL*100))+'%"></i></div></div>' : '';
      shell(
        '<div class="check"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>'+
        '<h1 class="q center">¡Gracias! 🌱</h1>'+
        '<p class="lead center">Tu aporte ayuda a que Presu lea tu banco —y el de mucha gente más. <b>El original nunca salió de tu equipo.</b></p>'+
        prog+
        '<p class="lead center" style="margin-top:18px">¿Conoces a alguien con otro banco? Entre más formatos, mejor lee Presu.</p>'+
        '<div class="nav" style="justify-content:center">'+
          '<a class="btn btn-wa" href="https://wa.me/?text='+waText+'" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.597 20.13c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.876-.607zM17.04 14.815c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg> Compartir por WhatsApp</a>'+
          '<a class="btn btn-ghost" href="/muro">Ver el Muro</a>'+
        '</div>'+
        '<div class="nav" style="justify-content:center;margin-top:10px"><button class="skip" id="again">Aportar otro documento</button></div>'+
        '<p class="consent2 center">Tu plata, clara. 🌿</p>'
      );
      document.getElementById('again').addEventListener('click', function(){ items=[]; editIdx=0; meta.banco=''; meta.tipo=''; phase='upload'; render(); });
    }

    function confetti(){
      var colors=['#34D399','#5EEAB8','#F4F4F3','#0E9F6E'];
      for(var i=0;i<26;i++){ var c=document.createElement('i'); c.style.left=(Math.random()*100)+'%';
        c.style.background=colors[i%colors.length]; c.style.animationDuration=(1.6+Math.random()*1.4)+'s';
        c.style.animationDelay=(Math.random()*.25)+'s'; confEl.appendChild(c); }
      setTimeout(function(){ confEl.innerHTML=''; }, 3600);
    }

    function back(){
      if(phase==='upload'){ phase='intro'; render(); }
      else if(phase==='edit'){ if(editIdx>0){ editIdx--; render(); } else { items=[]; phase='upload'; render(); } }
      else if(phase==='form'){ editIdx=items.length-1; phase='edit'; render(); }
    }
    backEl.addEventListener('click', back);

    boot();
  })();
  </script>
  <script is:inline>
