---
import StaticPage from '../layouts/StaticPage.astro';
---
<StaticPage title="Panel de Fundador · Presu" description="Tu progreso de referidos en Presu: tu link para invitar, tus recompensas y el ranking de Fundadores." noindex={true}>
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

  <header class="site-header">
    <div class="sh-wrap">
      <div class="sh-brand">
        <a class="sh-logo" href="/" aria-label="Presu — inicio"><span class="wordmark"><span class="wm-bar" aria-hidden="true"></span><span class="wm-text">presu</span></span></a>
        <a class="sh-endorse" href="https://asimetrica.co" target="_blank" rel="noopener"><span>de</span><img src="/asimetrica-logo.webp" alt="Asimétrica" /></a>
      </div>
      <nav class="sh-nav" id="sh-nav">
        <a href="/#como">Cómo</a>
        <a href="/#privacidad">Privacidad</a>
        <a href="/#planes">Planes</a>
        <a href="/aporta">Aporta 🌱</a>
      </nav>
      <div class="sh-actions"><a class="sh-cta" href="/#waitlist">Únete a la lista</a><button class="sh-burger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="sh-nav"><span></span><span></span><span></span></button></div>
    </div>
  </header>
  <div class="wrap">
    <div class="eb">Panel de Fundador</div>

    <div class="card" id="loading" style="text-align:center;color:var(--mut)">Cargando tu progreso…</div>

    <div id="panel" style="display:none">
      <div class="card">
        <div class="big"><span id="count">0</span> <small>referidos efectivos</small></div>
        <div class="next" id="nextLine"></div>
        <div class="bar"><i id="barFill" style="width:0%"></i></div>
        <ul class="tiers" id="tiers"></ul>
      </div>

      <div class="card" id="circuloCard" style="display:none"></div>

      <div class="card">
        <div class="label">Tu link para invitar</div>
        <div class="linkbox">
          <input id="link" readonly />
          <button class="btn btn-mint" id="copyBtn">Copiar</button>
        </div>
        <div class="share">
          <a class="btn btn-mint" id="waBtn" target="_blank" rel="noopener">Compartir por WhatsApp</a>
          <button class="btn btn-ghost" id="copyMsg">Copiar mensaje</button>
        </div>
        <p class="muted">Solo cuentan los amigos que se inscriban de verdad (correo nuevo y válido).</p>
      </div>

      <div class="card">
        <h2>Ranking de Fundadores</h2>
        <p class="muted" style="margin-top:0">El <b style="color:var(--mint)">Top 3</b> al cierre se lleva el premio: acompañamiento 1:1 en finanzas (3 meses) + libro (valor $1.500.000), gratis.</p>
        <ul class="rank" id="rank"></ul>
      </div>
    </div>
  </div>
  <div class="toast" id="toast">¡Copiado!</div>

  <style is:global>
  :root{--mint:#34D399;--mint-bright:#5EEAB8;--ink:#08231A;--tx:#F4F4F3;--mut:#A1A1A6;--mut2:#6B6B72;--bg:#08080A;--bg2:#101014;--line:rgba(255,255,255,.1);--head:"Space Grotesk",sans-serif;--mono:"JetBrains Mono",monospace}
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--tx);font-family:"Hanken Grotesk",sans-serif;line-height:1.5}
  .wrap{max-width:560px;margin:0 auto;padding:40px 20px 60px}
  .brand{font-family:var(--head);font-weight:700;font-size:24px;letter-spacing:-.02em;margin-bottom:6px}
  .brand span{color:var(--mint)}
  .eb{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--mint);margin-bottom:26px}
  .card{background:var(--bg2);border:1px solid var(--line);border-radius:20px;padding:24px;margin-bottom:16px}
  .big{font-family:var(--head);font-weight:700;font-size:3.2rem;line-height:1;color:#fff;font-variant-numeric:tabular-nums}
  .big small{font-size:1rem;color:var(--mut);font-weight:500;font-family:"Hanken Grotesk"}
  .next{color:var(--mut);font-size:.95rem;margin-top:10px}
  .next b{color:var(--mint-bright)}
  .bar{height:10px;border-radius:999px;background:#1B1B20;overflow:hidden;margin:16px 0 0}
  .bar>i{display:block;height:100%;background:linear-gradient(90deg,var(--mint),var(--mint-bright));border-radius:999px;transition:width .6s cubic-bezier(.2,.7,.2,1)}
  .tiers{list-style:none;margin:14px 0 0;padding:0;display:flex;flex-direction:column;gap:9px}
  .tiers li{display:flex;gap:10px;align-items:flex-start;font-size:.93rem;color:var(--mut)}
  .tiers li.on{color:var(--tx)}
  .tiers .dot{flex:none;width:20px;height:20px;border-radius:50%;border:1.5px solid var(--line);display:grid;place-items:center;font-size:11px;margin-top:2px}
  .tiers li.on .dot{background:var(--mint);border-color:var(--mint);color:var(--ink)}
  .tiers b{color:var(--tx)}
  .label{font-size:.8rem;color:var(--mut2);text-transform:uppercase;letter-spacing:.08em;font-family:var(--mono);margin-bottom:10px}
  .linkbox{display:flex;gap:8px}
  .linkbox input{flex:1;min-width:0;background:var(--bg);border:1px solid var(--line);border-radius:12px;padding:12px 14px;color:var(--mint-bright);font-family:var(--mono);font-size:13px}
  .btn{border:0;border-radius:12px;padding:12px 16px;font-weight:700;font-size:.92rem;cursor:pointer;font-family:"Hanken Grotesk";white-space:nowrap}
  .btn-mint{background:var(--mint);color:var(--ink)}
  .btn-ghost{background:rgba(255,255,255,.06);color:#fff;border:1px solid var(--line)}
  .share{display:flex;gap:8px;margin-top:10px}
  .share a{flex:1;text-align:center;text-decoration:none}
  .rank{list-style:none;margin:0;padding:0}
  .rank li{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--line);font-size:.95rem}
  .rank li:last-child{border-bottom:0}
  .rank .pos{width:26px;font-family:var(--mono);color:var(--mut2);font-size:.9rem}
  .rank .nm{flex:1;color:var(--tx)}
  .rank .ct{font-family:var(--mono);color:var(--mint-bright);font-weight:600}
  .rank li.top3 .pos{color:var(--mint)}
  .muted{color:var(--mut2);font-size:.82rem;margin-top:14px}
  .toast{position:fixed;left:50%;bottom:24px;transform:translateX(-50%) translateY(20px);background:var(--mint);color:var(--ink);font-weight:700;padding:11px 20px;border-radius:999px;opacity:0;transition:.25s;font-size:.9rem}
  .toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
  h2{font-family:var(--head);font-weight:600;font-size:1.1rem;margin:0 0 4px}
  /* wordmark */
  .wordmark{position:relative;display:inline-flex;align-items:center;line-height:.9}
  .wm-text{position:relative;z-index:1;font-family:var(--head);font-weight:700;font-size:1.375rem;letter-spacing:-.05em;color:var(--tx);line-height:.9}
  .wm-bar{position:absolute;left:-5%;right:-8%;top:53%;height:.36em;border-radius:999px;background:var(--mint);transform:rotate(-9deg);z-index:0}
  /* Site header (igual al resto del sitio) */
  .site-header{position:sticky;top:0;z-index:100;background:rgba(8,8,10,.72);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--line)}
  .sh-wrap{max-width:1200px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;text-align:left}
  .sh-brand{display:flex;align-items:center;gap:12px;min-width:0}
  .sh-logo{display:inline-flex;text-decoration:none}
  .sh-endorse{display:inline-flex;align-items:center;gap:7px;padding-left:12px;border-left:1px solid var(--line);font-family:"Hanken Grotesk",sans-serif;font-size:.8rem;font-weight:500;color:var(--mut2);text-decoration:none;white-space:nowrap}
  .sh-endorse img{height:.95rem;width:auto;display:block}
  .sh-nav{display:flex;align-items:center;gap:26px}
  .sh-nav a{font-family:"Hanken Grotesk",sans-serif;font-size:1rem;font-weight:500;color:var(--mut);text-decoration:none;transition:color .16s}
  .sh-nav a:hover{color:var(--tx)}
  .sh-cta{display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:9px 20px;border-radius:999px;background:var(--mint);color:#06231A;font-family:"Hanken Grotesk",sans-serif;font-weight:700;font-size:.9rem;text-decoration:none;white-space:nowrap;transition:background .16s}
  .sh-cta:hover{background:var(--mint-bright)}
  .sh-actions{display:flex;align-items:center;gap:10px}
.sh-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:42px;height:42px;padding:0;background:none;border:1px solid var(--line);border-radius:11px;cursor:pointer}
.sh-burger span{display:block;width:20px;height:2px;margin:0 auto;background:var(--tx);border-radius:2px;transition:transform .22s,opacity .22s}
.sh-burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.sh-burger[aria-expanded="true"] span:nth-child(2){opacity:0}
.sh-burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
@media(max-width:640px){
  .sh-endorse{display:none}
  .sh-burger{display:flex}
  .sh-wrap{padding:12px 16px}
  .sh-nav{position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:stretch;gap:0;padding:6px 16px 14px;background:var(--bg);border-bottom:1px solid var(--line);display:none}
  .site-header.is-open .sh-nav{display:flex}
  .sh-nav a{padding:14px 4px;font-size:1.05rem;border-bottom:1px solid var(--line)}
  .sh-nav a:last-child{border-bottom:0}
}
  </style>

  <script is:inline>
  (function(){
    var API = ['presu.asimetrica.co','presu.io','www.presu.io','presu.com.co'].indexOf(location.hostname) !== -1
      ? 'https://presu-waitlist.asimetrica.workers.dev'
      : 'https://presu-waitlist-staging.asimetrica.workers.dev';
    var code = (new URLSearchParams(location.search).get('code')||'').trim().toUpperCase();
    var TIERS = [
      {min:3, label:'<b>Fundador</b> — insignia + Muro de Fundadores'},
      {min:7, label:'<b>Círculo privado</b> — grupo + voto en el roadmap'},
      {min:15, label:'<b>Masterclass</b> de Asimétrica'},
    ];
    function toast(t){ var el=document.getElementById('toast'); el.textContent=t; el.classList.add('on'); setTimeout(function(){el.classList.remove('on');},1600); }
    function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c];}); }
    function safeUrl(u){ u=String(u||''); return /^https?:\/\//i.test(u) ? esc(u) : '#'; }

    if(!code){ document.getElementById('loading').textContent='Falta tu código. Abre el link de tu correo.'; return; }

    var shareLink = 'https://presu.io/?ref='+code;
    var shareMsg = 'Me sumé a Presu 🌿 — reúne tus gastos de todos tus bancos y te dice si vas bien, privado y en tu equipo. Entrando ahora es gratis. Te dejo mi link: '+shareLink;

    Promise.all([
      fetch(API+'/me?code='+code).then(function(r){return r.json();}),
      fetch(API+'/leaderboard').then(function(r){return r.json();}).catch(function(){return {top:[]};})
    ]).then(function(res){
      var me=res[0], lb=res[1];
      if(me && me.error){ document.getElementById('loading').textContent='No encontramos ese código.'; return; }
      document.getElementById('loading').style.display='none';
      document.getElementById('panel').style.display='block';

      var n = me.referrals||0;
      document.getElementById('count').textContent = n;
      var nextMin = me.next ? me.next.min : 15;
      document.getElementById('nextLine').innerHTML = me.next
        ? 'Vas <b>'+n+'/'+me.next.min+'</b> para <b>'+me.next.name+'</b>'
        : '¡Lo desbloqueaste todo! Ahora apunta al <b>Top 3</b> del ranking 🏆';
      document.getElementById('barFill').style.width = Math.min(100, Math.round(n/nextMin*100))+'%';

      document.getElementById('link').value = shareLink;
      document.getElementById('waBtn').href = 'https://wa.me/?text='+encodeURIComponent(shareMsg);

      var tl = TIERS.map(function(t){
        var on = n>=t.min;
        return '<li class="'+(on?'on':'')+'"><span class="dot">'+(on?'✓':'')+'</span><span>'+t.min+' → '+t.label+'</span></li>';
      }).join('');
      document.getElementById('tiers').innerHTML = tl;

      if (me.unlock) {
        var cc = document.getElementById('circuloCard');
        cc.style.display = 'block';
        var mc = me.unlock.masterclass
          ? '<li class="on"><span class="dot">🎓</span><span><b>Masterclass de Asimétrica</b> — te avisamos la fecha</span></li>'
          : '<li><span class="dot"></span><span><b>Masterclass de Asimétrica</b> — a los 15 referidos</span></li>';
        cc.innerHTML = '<h2>Círculo privado 🎉</h2>'
          + '<p class="muted" style="margin-top:0">Tu acceso de Círculo: grupo privado + voto en el roadmap.</p>'
          + (me.unlock.whatsapp ? '<a class="btn btn-mint" style="display:inline-block;text-decoration:none;margin:4px 0 14px" href="'+safeUrl(me.unlock.whatsapp)+'" target="_blank" rel="noopener">Unirme al grupo privado →</a>' : '')
          + '<ul class="tiers"><li class="on"><span class="dot">🗳️</span><span><b>Voto en el roadmap</b> — <a href="/roadmap.html?code='+encodeURIComponent(code)+'" style="color:var(--mint-bright)">abrir el tablero →</a></span></li>' + mc + '</ul>';
      }

      var top = (lb && lb.top) || [];
      document.getElementById('rank').innerHTML = top.length
        ? top.map(function(x,i){ return '<li class="'+(i<3?'top3':'')+'"><span class="pos">'+(i+1)+'</span><span class="nm">'+esc(x.name)+'</span><span class="ct">'+(x.count|0)+'</span></li>'; }).join('')
        : '<li><span class="nm" style="color:var(--mut)">Aún nadie en el ranking. ¡Sé el primero!</span></li>';
    }).catch(function(){ document.getElementById('loading').textContent='No pudimos cargar tu progreso. Intenta de nuevo.'; });

    document.getElementById('copyBtn').addEventListener('click', function(){ navigator.clipboard.writeText(shareLink).then(function(){toast('¡Link copiado!');}); });
    document.getElementById('copyMsg').addEventListener('click', function(){ navigator.clipboard.writeText(shareMsg).then(function(){toast('¡Mensaje copiado!');}); });
  })();
  </script>
  <script is:inline>
  (function(){var h=document.querySelector(".site-header"),b=h&&h.querySelector(".sh-burger");if(!h||!b)return;function c(){h.classList.remove("is-open");b.setAttribute("aria-expanded","false");}b.addEventListener("click",function(){var o=h.classList.toggle("is-open");b.setAttribute("aria-expanded",o?"true":"false");});h.querySelectorAll(".sh-nav a").forEach(function(a){a.addEventListener("click",c);});document.addEventListener("keydown",function(e){if(e.key==="Escape")c();});})();
  </script>
</StaticPage>
