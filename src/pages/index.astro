</style>

<script>
  import { apiBase } from '../scripts/api.js';
  import { send, isNuevaOla, enterNuevaOla } from '../scripts/waitlist.js';
  import { BETA, target, parts } from '../scripts/countdown.js';

  const REDUCE = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const API = apiBase(location.hostname);

  // Código de referido entrante (?ref=) — se recuerda por si vuelve luego.
  const REF = (() => {
    try {
      const u = new URLSearchParams(location.search).get('ref');
      if (u) localStorage.setItem('presu_ref', u.toUpperCase());
      return (localStorage.getItem('presu_ref') || '').toUpperCase();
    } catch {
      return '';
    }
  })();

  const track = (perfil: string, origen: string) => {
    if (typeof (window as any).gtag === 'function') (window as any).gtag('event', 'generate_lead', { perfil, origen });
  };

  // ── Count-up: la cifra cuenta hasta su valor (respeta reduced-motion). ──
  function countUp(el: HTMLElement) {
    if (el.dataset.counted) return;
    el.dataset.counted = '1';
    const raw = (el.textContent || '').trim();
    const m = raw.match(/^([^\d-]*)(-?[\d.,]+)(.*)$/);
    if (!m) return;
    const pre = m[1];
    const numStr = m[2];
    const suf = m[3];
    const hasComma = numStr.indexOf(',') >= 0;
    const val = parseFloat(numStr.replace(/\./g, '').replace(',', '.'));
    if (isNaN(val)) return;
    const dec = hasComma ? (numStr.split(',')[1] || '').length : 0;
    const fmt = (n: number) =>
      pre + n.toLocaleString('es-CO', { minimumFractionDigits: dec, maximumFractionDigits: dec }) + suf;
    const dur = 1100;
    let t0: number | null = null;
    const step = (ts: number) => {
      if (t0 === null) t0 = ts;
      const p = Math.min(1, (ts - t0) / dur);
      el.textContent = fmt(val * (1 - Math.pow(1 - p, 3)));
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = raw;
    };
    requestAnimationFrame(step);
  }

  // ── Confeti de celebración al inscribirse (respeta reduced-motion). ──
  function celebrate() {
    if (REDUCE) return;
    const cv = document.createElement('canvas');
    cv.style.cssText =
      'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:120';
    document.body.appendChild(cv);
    const ctx = cv.getContext('2d');
    if (!ctx) {
      cv.remove();
      return;
    }
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = window.innerWidth;
    const h = window.innerHeight;
    cv.width = w * dpr;
    cv.height = h * dpr;
    ctx.scale(dpr, dpr);
    const COLORS = ['#34D399', '#5EEAB8', '#F4F4F3', '#FBBF24', '#818CF8'];
    const parts = Array.from({ length: 96 }, () => ({
      x: w / 2 + (Math.random() - 0.5) * w * 0.5,
      y: h * 0.34 + (Math.random() - 0.5) * 80,
      vx: (Math.random() - 0.5) * 9,
      vy: Math.random() * -9 - 4,
      g: 0.28 + Math.random() * 0.12,
      s: 5 + Math.random() * 6,
      rot: Math.random() * Math.PI,
      vr: (Math.random() - 0.5) * 0.32,
      c: COLORS[Math.floor(Math.random() * COLORS.length)],
    }));
    const DUR = 1700;
    let t0: number | null = null;
    const frame = (ts: number) => {
      if (t0 === null) t0 = ts;
      const el = ts - t0;
      ctx.clearRect(0, 0, w, h);
      parts.forEach((p) => {
        p.vy += p.g;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.globalAlpha = Math.max(0, 1 - el / DUR);
        ctx.fillStyle = p.c;
        ctx.fillRect(-p.s / 2, -p.s / 2, p.s, p.s * 0.62);
        ctx.restore();
      });
      if (el < DUR) requestAnimationFrame(frame);
      else cv.remove();
    };
    requestAnimationFrame(frame);
  }

  // ── CTA tras inscribirse: convierte al nuevo inscrito en referidor. ──
  function referralCTA(code: string) {
    if (!code) return '';
    return (
      '<div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">' +
      '<div style="font-weight:600;color:var(--text-primary);margin-bottom:6px">Ahora vuélvete Fundador 🚀</div>' +
      '<div style="font-size:.9rem;color:var(--text-secondary);margin-bottom:12px">Invita amigos y desbloquea bonos extra. El Top 3 se lleva acompañamiento 1:1 + libro, gratis.</div>' +
      '<a href="/fundador.html?code=' +
      code +
      '" style="display:inline-flex;align-items:center;gap:7px;background:var(--presu-emerald);color:var(--text-on-accent);font-weight:700;text-decoration:none;padding:11px 18px;border-radius:12px;font-size:.92rem">Ver mi panel e invitar →</a>' +
      '</div>'
    );
  }

  // ── Contador de registros en vivo (Worker/KV). ──
  let lastCount = 0;
  const fmtCount = (n: number) => {
    try {
      return n.toLocaleString('es-CO');
    } catch {
      return String(n);
    }
  };
  function renderCount(total: number) {
    if (total <= 0) return;
    const first = lastCount === 0;
    lastCount = total;
    document.querySelectorAll<HTMLElement>('.count').forEach((el) => {
      el.textContent = fmtCount(total);
      if (first && !REDUCE) countUp(el);
      else if (!first && !REDUCE) {
        el.classList.remove('bumped');
        void el.offsetWidth; // reflow para reiniciar el pulso
        el.classList.add('bumped');
      }
    });
    document.querySelectorAll('.proof').forEach((el) => el.classList.remove('hidden'));
  }
  function loadCount() {
    fetch(API + '/count', { cache: 'no-store' })
      .then((r) => r.json())
      .then((d) => {
        if (d && typeof d.count === 'number') renderCount(d.count);
      })
      .catch(() => {});
  }
  function bumpCount() {
    if (lastCount > 0) renderCount(lastCount + 1);
    setTimeout(loadCount, 1800);
  }
  loadCount();
  setInterval(loadCount, 15000);

  // ── Ventana post-registro: encuesta opcional (Nombre → WhatsApp → perfil) en un iframe ──
  // Reutiliza encuesta.html en modo nuevo+embed; guarda incremental (cada campo apenas se llena).
  let connectShown = false;
  function openConnect(email: string) {
    if (connectShown || !email) return;
    connectShown = true;
    const ov = document.getElementById('connect-modal');
    if (!ov) return;
    const iframe = ov.querySelector<HTMLIFrameElement>('iframe');
    if (iframe) iframe.src = '/encuesta.html?e=' + encodeURIComponent(email) + '&nuevo=1&embed=1';
    ov.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    if (typeof (window as any).gtag === 'function') (window as any).gtag('event', 'connect_open');
  }
  function closeConnect() {
    const ov = document.getElementById('connect-modal');
    if (ov) ov.classList.remove('is-open');
    document.body.style.overflow = '';
  }
  (() => {
    const ov = document.getElementById('connect-modal');
    if (!ov) return;
    ov.addEventListener('click', (e) => {
      if (e.target === ov) closeConnect();
    });
    ov.querySelector('.connect-modal__close')?.addEventListener('click', closeConnect);
  })();
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeConnect();
  });
  window.addEventListener('message', (e: MessageEvent) => {
    const d = e && (e.data as any);
    if (d && (d.presu === 'survey-close' || d.presu === 'survey-complete')) {
      closeConnect();
    }
  });

  // ── Countdown: usa las funciones puras portadas (BETA/target/parts) ──
  (function () {
    const cd = document.getElementById('countdown');
    if (!cd) return;
    const dEl = document.getElementById('cd-d');
    const hEl = document.getElementById('cd-h');
    const mEl = document.getElementById('cd-m');
    const sEl = document.getElementById('cd-s');
    const pad = (n: number) => String(n).padStart(2, '0');
    let timer: number;
    if (Date.now() >= BETA) enterNuevaOla(); // si la beta ya cerró, arranca en modo Nueva Ola
    const tick = () => {
      const now = Date.now();
      if (now >= BETA) enterNuevaOla(); // idempotente
      const diff = target(now) - now;
      if (diff <= 0) {
        cd.classList.add('is-live');
        [dEl, hEl, mEl, sEl].forEach((e) => e && (e.textContent = '00'));
        clearInterval(timer);
        return;
      }
      const p = parts(diff);
      if (dEl) dEl.textContent = pad(p.d);
      if (hEl) hEl.textContent = pad(p.h);
      if (mEl) mEl.textContent = pad(p.m);
      if (sEl) sEl.textContent = pad(p.s);
    };
    tick();
    timer = window.setInterval(tick, 1000);
  })();

  // ── Micro-feedback en formularios ──
  function shakeErr(el: HTMLInputElement) {
    el.classList.add('err');
    if (!REDUCE) {
      el.classList.remove('shake');
      void el.offsetWidth; // reflow para reiniciar la animación
      el.classList.add('shake');
      setTimeout(() => el.classList.remove('shake'), 450);
    }
    const clear = () => {
      el.classList.remove('err');
      el.removeEventListener('input', clear);
    };
    el.addEventListener('input', clear);
  }
  function btnLoading(f: HTMLFormElement, on: boolean) {
    const b = f.querySelector<HTMLButtonElement>('button[type=submit]');
    if (b) {
      b.classList.toggle('loading', on);
      b.disabled = on;
    }
  }

  // ── Hero capture ──
  const heroForm = document.getElementById('hero-form') as HTMLFormElement | null;
  if (heroForm) {
    const heroEmail = document.getElementById('hero-email') as HTMLInputElement;
    const heroErr = document.getElementById('hero-err') as HTMLElement;
    const heroOk = document.getElementById('hero-ok') as HTMLElement;
    heroForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = heroEmail.value.trim();
      if (!EMAIL_RE.test(email)) {
        heroErr.textContent = 'Revisa el correo —parece que le falta algo.';
        heroErr.style.display = 'block';
        shakeErr(heroEmail);
        heroEmail.focus();
        return;
      }
      heroErr.style.display = 'none';
      btnLoading(heroForm, true);
      const late = isNuevaOla();
      send(
        { perfil: 'persona', correo: email, origen: late ? 'tanda2' : 'hero', ref: REF },
        (res) => {
          heroForm.style.display = 'none';
          if (late) {
            heroOk.querySelector('strong')!.textContent = '¡Listo, estás en la Nueva Ola! 🌊';
            heroOk.querySelector('span span')!.textContent =
              'Abre el 15 de julio a las 4pm. Comparte tu link para subir en la fila.';
          }
          heroOk.classList.remove('hidden');
          heroOk.classList.add('pop-in');
          if (res && (res as any).ref) heroOk.insertAdjacentHTML('afterend', referralCTA((res as any).ref));
          bumpCount();
          celebrate();
          track('persona', late ? 'tanda2' : 'hero');
          openConnect(email);
        },
        () => {
          btnLoading(heroForm, false);
          heroErr.textContent = 'Algo falló de nuestro lado. Reintenta en un momento.';
          heroErr.style.display = 'block';
        },
        () => {
          heroForm.style.display = 'none';
          heroOk.querySelector('strong')!.textContent = '¡Ya estás inscrito! 🎉';
          heroOk.querySelector('span span')!.textContent = late
            ? 'Si eres pionero, ya tienes acceso (revisa tu correo 📩).'
            : 'Ese correo ya está inscrito. Te avisamos primero cuando abramos.';
          heroOk.classList.remove('hidden');
          heroOk.classList.add('pop-in');
          openConnect(email);
        }
      );
    });
  }

  // ── Formulario completo (Nueva Ola) ──
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  if (form) {
    const empresaFields = document.getElementById('empresa-fields') as HTMLElement;
    const empresaInput = document.getElementById('empresa') as HTMLInputElement;
    const syncPerfil = () => {
      const esEmpresa =
        (form.querySelector('input[name=perfil]:checked') as HTMLInputElement).value === 'empresa';
      empresaFields.classList.toggle('hidden', !esEmpresa);
      if (empresaInput) empresaInput.required = esEmpresa;
    };
    form.querySelectorAll('input[name=perfil]').forEach((r) => r.addEventListener('change', syncPerfil));
    document.querySelectorAll('[data-perfil=empresa]').forEach((a) => {
      a.addEventListener('click', () => {
        (form.querySelector('input[name=perfil][value=empresa]') as HTMLInputElement).checked = true;
        syncPerfil();
      });
    });
    const showError = (id: string, show: boolean) => {
      const el = document.getElementById(id);
      if (el) el.style.display = show ? 'block' : 'none';
    };
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if ((form as any).botcheck.value) return;
      const email = (form as any).email.value.trim();
      const emailOk = EMAIL_RE.test(email);
      const consentOk = (form as any).consent.checked;
      showError('email-err', !emailOk);
      showError('consent-err', !consentOk);
      if (!emailOk) {
        shakeErr((form as any).email);
        (form as any).email.focus();
        return;
      }
      if (!consentOk) {
        (form as any).consent.focus();
        return;
      }
      showError('wl-err', false);
      btnLoading(form, true);
      const perfil = (form.querySelector('input[name=perfil]:checked') as HTMLInputElement).value;
      send(
        {
          perfil,
          correo: email,
          nombre: (form as any).nombre.value.trim(),
          empresa: perfil === 'empresa' ? (form as any).empresa.value.trim() : '',
          empleados: perfil === 'empresa' ? (form as any).empleados.value.trim() : '',
          ref: REF,
        },
        (res) => {
          form.classList.add('hidden');
          const s = document.getElementById('waitlist-success')!;
          s.classList.remove('hidden');
          s.classList.add('pop-in');
          if (res && (res as any).ref) s.insertAdjacentHTML('beforeend', referralCTA((res as any).ref));
          bumpCount();
          celebrate();
          track(perfil, 'form');
          openConnect(email);
        },
        () => {
          btnLoading(form, false);
          showError('wl-err', true);
        },
        () => {
          const s = document.getElementById('waitlist-success')!;
          s.querySelector('h3')!.textContent = '¡Ya estás en la lista! 🎉';
          s.querySelector('p')!.textContent =
            'Ese correo ya está inscrito. Te avisamos primero cuando abramos cupos.';
          form.classList.add('hidden');
          s.classList.remove('hidden');
          s.classList.add('pop-in');
          openConnect(email);
        }
      );
    });
  }

  // ── Reveal on scroll ──
  const reveals = Array.from(document.querySelectorAll('.reveal'));
  document.body.classList.add('reveal-ready');
  if ('IntersectionObserver' in window && !REDUCE) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            en.target.classList.add('in');
            io.unobserve(en.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -10% 0px' }
    );
    reveals.forEach((el) => io.observe(el));
    // Red de seguridad: nada queda oculto si el observer falla.
    setTimeout(() => reveals.forEach((el) => el.classList.add('in')), 1600);
  } else {
    reveals.forEach((el) => el.classList.add('in'));
  }

  // ── Count-up de cifras al entrar en viewport (hero + secciones inferiores) ──
  const figSel = '.stat-card__value, .presu-showcase .sv';
  if (!REDUCE) {
    if ('IntersectionObserver' in window) {
      const io2 = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) {
              countUp(en.target as HTMLElement);
              io2.unobserve(en.target);
            }
          });
        },
        { threshold: 0.4 }
      );
      document.querySelectorAll<HTMLElement>(figSel).forEach((el) => io2.observe(el));
      // Red de seguridad: si el observer no dispara, cuenta igual.
      setTimeout(() => document.querySelectorAll<HTMLElement>(figSel).forEach(countUp), 1600);
    } else {
      document.querySelectorAll<HTMLElement>(figSel).forEach(countUp);
    }
  }
</script>
