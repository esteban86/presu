---
// index.astro — la landing rediseñada de Presu (DS v2 "Esmeralda").
// Narrativa "problema primero"; hero "split". Reúne los componentes de
// ui/ (Section, VerdictCard, StatCard, BudgetBar, BanksStrip, FaqItem) y
// la lógica portada de src/scripts/ (countdown, waitlist, api). El markup
// del hero PROVEE el contrato de DOM que consumen countdown.js y
// waitlist.js sin cambios: .hero-grid {.pill-badge, h1, .pitch, .sub},
// #hero-form + #hero-email, #countdown {.cd-top/.cd-live/.cd-note,
// #cd-d/#cd-h/#cd-m/#cd-s}, #late-ramps, #os-eb-date, #waitlist-lede.
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import VerdictCard from '../components/ui/VerdictCard.astro';
import StatCard from '../components/ui/StatCard.astro';
import BudgetBar from '../components/ui/BudgetBar.astro';
import CategoryDonut from '../components/ui/CategoryDonut.astro';
import AppWindow from '../components/ui/AppWindow.astro';
import BanksStrip from '../components/ui/BanksStrip.astro';
import Showcase from '../components/ui/Showcase.astro';
import FaqItem from '../components/ui/FaqItem.astro';
import { formatCOPCompact, CATEGORIES } from '../lib/format.js';
import homeJsonLd from '../data/home-jsonld.json';

const ingresos = formatCOPCompact(6420000); // "$6,42M"
const gastos = formatCOPCompact(4740000); // "$4,74M"
const balance = formatCOPCompact(1680000); // "$1,68M" (= ingresos − gastos)

// Gastos por categoría (dona del panel) — suman exactamente 4.740.000 = `gastos`.
const spendByCategory = [
  { ...CATEGORIES.vivienda, amount: '$1.500.000', value: 1500000 },
  { ...CATEGORIES.mercado, amount: '$900.000', value: 900000 },
  { ...CATEGORIES.restaurantes, amount: '$620.000', value: 620000 },
  { ...CATEGORIES.salud, amount: '$420.000', value: 420000 },
  { ...CATEGORIES.transporte, amount: '$480.000', value: 480000 },
  { ...CATEGORIES.otros, amount: '$820.000', value: 820000 },
];

// El problema — la tensión, con la frase humana primero.
const problems = [
  {
    tone: 'negative',
    icon: 'coins',
    title: 'La plata se va sin saber en qué',
    body: 'Ganas bien, pero a fin de mes no cuadra. Sin un panorama claro, decidir es adivinar.',
  },
  {
    tone: 'info',
    icon: 'phone',
    title: 'Cuatro apps de bancos distintas',
    body: 'Bancolombia por aquí, Nu por allá, la tarjeta en otra. Nunca ves todo junto.',
  },
  {
    tone: 'positive',
    icon: 'cloud',
    title: 'Las demás apps suben todo a la nube',
    body: 'Para organizarte te piden entregar tus datos financieros a un servidor ajeno. No, gracias.',
  },
];

// El giro — cómo funciona en 3 pasos.
const steps = [
  {
    n: '1',
    title: 'Importas tu extracto',
    body: 'Arrastras el PDF del banco —o hasta un pantallazo. Sin claves ni conexión a tu banca en línea.',
  },
  {
    n: '2',
    title: 'Presu lo organiza solo',
    body: 'Detecta el banco y categoriza cada movimiento en segundo plano. Cuando abres, ya está hecho.',
  },
  {
    n: '3',
    title: 'Lo ves en una frase',
    body: 'Cuánto entró, cuánto salió y qué te queda. La respuesta primero; los números, si los quieres.',
  },
];

// Mira por dentro — movimientos reales (Colombia).
const txns = [
  { emoji: '💰', name: 'Nómina', bank: 'Bancolombia', amount: '+$5.200.000', income: true },
  { emoji: '🏠', name: 'Arriendo', bank: 'Davivienda', amount: '−$1.500.000' },
  { emoji: '🛒', name: 'Éxito Poblado', bank: 'Bancolombia', amount: '−$124.300' },
  { emoji: '🍔', name: 'Rappi', bank: 'Nu', amount: '−$32.500' },
  { emoji: '🎬', name: 'Netflix', bank: 'RappiCard', amount: '−$44.900' },
];

// FAQ — preguntas reales de la landing en vivo.
const faqs = [
  {
    q: '¿Es seguro? ¿Dónde quedan mis datos?',
    a: 'Tus datos quedan cifrados en tu propio computador, no en un servidor ni en la nube. Presu es local-first: la información no sale de tu equipo, así que nadie más —ni Asimétrica— puede verla.',
    open: true,
  },
  {
    q: '¿Necesito dar la clave de mi banco?',
    a: 'No. Presu no se conecta a tu banca en línea ni te pide usuario o clave. Solo importas el PDF de tu extracto (o un pantallazo) y Presu lo lee.',
  },
  {
    q: '¿Qué bancos sirven?',
    a: 'Hoy: Bancolombia, Nu, Davivienda y RappiCard. Seguimos sumando más cada mes.',
  },
  {
    q: '¿Qué gano por entrar antes del lanzamiento?',
    a: 'Eres pionero: usas Presu completo gratis durante la beta, recibes la guía «De ruido a claridad» de Asimétrica, entras a una sesión de finanzas en vivo solo para pioneros, conservas un precio especial cuando salga el plan de pago y ayudas a decidir qué banco o función construimos después. A cambio, solo te pedimos tu feedback.',
  },
  {
    q: '¿Tiene costo?',
    a: 'Si entras como pionero (antes del 30 de junio), usas toda la beta gratis a cambio de tu feedback y conservas un precio especial. Después podrás seguir gratis con la importación manual y el panel básico; el plan completo tendrá un precio que definimos al lanzar.',
  },
  {
    q: '¿Funciona en Mac, Windows o celular?',
    a: 'Hoy funciona en computador, Mac y Windows. La versión para celular está en camino —te avisamos cuando esté lista.',
  },
];
---

<Base
  title="Presu — tus gastos personales, claros."
  description="Presu reúne tu plata de todos los bancos, la organiza sola y te dice —en una frase— si vas bien este mes. Todo cifrado en tu equipo: sin nube, sin cuentas."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(homeJsonLd)}></script>

  <!-- ══════════════════ 1 · HERO (split) ══════════════════ -->
  <section class="hero">
    <div class="hero-glow hero-glow--emerald" aria-hidden="true"></div>
    <div class="hero-glow hero-glow--indigo" aria-hidden="true"></div>

    <div class="hero-grid">
      <!-- Izquierda: el argumento + captura -->
      <div class="hero-copy">
        <span class="pill-badge"><span class="ping"></span> Beta de pioneros · gratis antes del 30 de junio</span>
        <h1>Tus gastos de todos los bancos, <span class="mark">claros</span>.</h1>
        <p class="pitch">Presu reúne tu plata de Bancolombia, Nu, Davivienda y más, la organiza sola y te dice —en una frase, no en una hoja de cálculo— a dónde se va y si vas bien este mes.</p>
        <p class="sub">Todo vive cifrado en tu equipo: sin nube, sin cuentas, sin que nadie más lo vea.</p>

        <div class="countdown" id="countdown">
          <span class="cd-top">Falta para abrir la beta</span>
          <div class="cd-units" role="timer" aria-label="Cuenta regresiva para la beta">
            <div class="cd-u"><b id="cd-d">00</b><span>días</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-u"><b id="cd-h">00</b><span>horas</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-u"><b id="cd-m">00</b><span>min</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-u"><b id="cd-s">00</b><span>seg</span></div>
          </div>
          <span class="cd-live">● La beta ya está abierta —entra y reclama tu acceso.</span>
          <p class="cd-note">Los <b>pioneros</b> entran antes del 30: prueban la beta, le dan forma con su feedback y usan <b>Presu completo, gratis</b>.</p>
        </div>

        <form id="hero-form" class="capture" novalidate>
          <div class="capture-row">
            <input type="email" id="hero-email" name="email" autocomplete="email" placeholder="tu@correo.com" aria-label="Tu correo" required />
            <button type="submit" class="capture-btn">Únete a la lista
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
          </div>
          <p class="capture-err" id="hero-err">Revisa el correo —parece que le falta algo.</p>
          <p class="capture-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            Gratis para empezar · Tus datos no salen de tu equipo · Sin spam
          </p>
        </form>

        <div class="capture-ok hidden" id="hero-ok" role="status">
          <span class="ok-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6 9 17l-5-5"></path></svg></span>
          <span><strong>¡Listo, ya estás dentro!</strong><span>Te escribimos primero cuando abramos cupos —sin afán, sin spam.</span></span>
        </div>

        <div class="proof hidden" id="proof-hero">
          <span class="avatars" aria-hidden="true"><i class="av"></i><i class="av"></i><i class="av"></i><i class="av"></i></span>
          <b class="count">—</b><span class="proof-txt">&nbsp;personas ya en la Nueva Ola</span>
        </div>

        <div id="late-ramps" class="late-ramps">
          <div class="ramp">🚀 <b>Salta la fila</b> — al unirte recibes tu link; cada amigo que invites te sube en la cola de la próxima tanda.</div>
          <a href="/aporta" class="ramp ramp-link">🌱 <b>Gánate tu cupo</b> — aporta un documento (anónimo, en tu equipo) y te invitamos antes que al resto <span class="arw">→</span></a>
        </div>
      </div>

      <!-- Derecha: la pieza firma — VerdictCard + categorías -->
      <div class="hero-viz">
        <AppWindow />
      </div>
    </div>
  </section>

  <!-- ══════════════════ 2 · EL PROBLEMA ══════════════════ -->
  <Section eyebrow="El problema">
    <div class="sec-head reveal">
      <h2>Llegas a fin de mes preguntándote <span class="mark">en qué</span> se fue la plata.</h2>
      <p class="sec-lead">Te suena, ¿cierto? No es que gastes de más. Es que nunca ves todo junto.</p>
    </div>
    <div class="cards">
      {problems.map((p) => (
        <div class="card reveal">
          <span class={`card-ic card-ic--${p.tone}`}>
            {p.icon === 'coins' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            )}
            {p.icon === 'phone' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
            )}
            {p.icon === 'cloud' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path></svg>
            )}
          </span>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- ══════════════════ 3 · EL GIRO — CÓMO FUNCIONA ══════════════════ -->
  <Section id="como" eyebrow="El giro">
    <div class="sec-head reveal">
      <h2>De un PDF a saber si vas bien, en <span class="mark">tres pasos</span>.</h2>
      <p class="sec-lead">Sin claves del banco. Sin hojas de cálculo. Sin subir nada a la nube.</p>
    </div>
    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <span class="step-n">{s.n}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- ══════════════════ 4 · MIRA POR DENTRO ══════════════════ -->
  <Section eyebrow="Mira por dentro">
    <div class="sec-head reveal">
      <h2>Todo tu dinero, en <span class="mark">una sola vista</span>.</h2>
      <p class="sec-lead">Ingresos, gastos, presupuestos y movimientos —sumados de todos tus bancos, al día.</p>
    </div>

    <div class="panel reveal">
      <div class="panel-head">
        <span class="panel-cap">Inicio · Junio 2026</span>
        <span class="panel-date">01 → 30 jun · 5 cuentas</span>
      </div>

      <div class="panel-stats">
        <StatCard label="↗ Ingresos" value={ingresos} delta="↑ 9,2%" deltaTone="positive" />
        <StatCard label="↘ Gastos" value={gastos} delta="↓ 8,4%" deltaTone="negative" />
        <StatCard label="▦ Balance" value={balance} delta="↑ 138,5%" deltaTone="positive" />
      </div>

      <div class="panel-cols">
        <div class="panel-donut">
          <span class="panel-sub">Gastos por categoría</span>
          <CategoryDonut segments={spendByCategory} total={gastos} caption="Junio" />
        </div>

        <div class="panel-txns">
          <span class="panel-sub">Últimos movimientos</span>
          <ul class="txns">
            {txns.map((t) => (
              <li class="txn">
                <span class="txn-ic">{t.emoji}</span>
                <span class="txn-main">
                  <span class="txn-name">{t.name}</span>
                  <span class="txn-bank">{t.bank}</span>
                </span>
                <span class:list={['txn-amt', { 'txn-amt--in': t.income }]}>{t.amount}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </Section>

  <!-- ══════════════════ 5 · BANCOS QUE LEE ══════════════════ -->
  <Section eyebrow="Bancos que lee">
    <div class="sec-head reveal">
      <h2>Lee los extractos de <span class="mark">tus bancos</span>.</h2>
      <p class="sec-lead">Arrastra el PDF y Presu detecta el banco solo. Sumamos más cada mes.</p>
    </div>
    <div class="reveal">
      <BanksStrip />
    </div>
  </Section>

  <!-- ══════════════════ Mira lo que verás por dentro (showcase) ══════════════════ -->
  <Showcase />

  <!-- ══════════════════ 6 · PRIVACIDAD (firma) ══════════════════ -->
  <Section id="privacidad" eyebrow="Privacidad que se siente">
    <div class="privacy reveal">
      <div class="privacy-glow" aria-hidden="true"></div>
      <h2>Tus datos viven en <span class="mark">tu equipo</span>. Punto.</h2>
      <p class="privacy-lead">Presu funciona <strong>local-first</strong>: tu información financiera se guarda <strong>cifrada en tu computador</strong>. No en un servidor, no en la nube, no con nosotros. No necesitas crear una cuenta, y de tu equipo solo sale lo que tú decidas exportar. <strong>Nadie más —ni Asimétrica— ve tus movimientos.</strong></p>
      <div class="privacy-pills">
        <span class="ppill">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Cifrado en tu dispositivo
        </span>
        <span class="ppill">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          Sin servidores, sin nube
        </span>
        <span class="ppill">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18.36 6.64A9 9 0 1 1 5.64 6.64"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
          Sin crear cuenta
        </span>
      </div>
    </div>
  </Section>

  <!-- ══════════════════ 6.5 · PARA EMPRESAS (B2B) ══════════════════ -->
  <Section id="equipos">
    <div class="b2b reveal">
      <div class="b2b-glow" aria-hidden="true"></div>
      <p class="b2b-eyebrow">Para empresas</p>
      <h2>Bienestar financiero para tu equipo, <span class="mark">sin tocar su privacidad</span>.</h2>
      <p class="b2b-lead">Ofrece Presu como beneficio. Tu gente ordena su plata y tú impulsas su tranquilidad —y nadie en la empresa ve sus datos, porque viven en el equipo de cada persona.</p>
      <a href="#waitlist" class="capture-btn b2b-cta" data-perfil="empresa">Quiero ofrecerlo en mi empresa
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>
  </Section>

  <!-- ══════════════════ 7 · PLANES (teaser) ══════════════════ -->
  <Section id="planes" eyebrow="Planes">
    <div class="sec-head reveal">
      <h2>Empiezas <span class="mark">gratis</span>. Siempre.</h2>
      <p class="sec-lead">Importa a mano y mira tu panel sin pagar nada. Cuando quieras todo automático, sube al plan completo.</p>
    </div>
    <div class="plans">
      <div class="plan reveal">
        <h3>Gratis</h3>
        <p class="plan-tag">Para empezar a ver claro</p>
        <ul class="plan-list">
          <li>Importación manual de extractos</li>
          <li>Categorización automática</li>
          <li>Panel básico de gastos y presupuestos</li>
        </ul>
      </div>
      <div class="plan plan--pro reveal">
        <span class="plan-badge">Recomendado</span>
        <h3>Plan completo</h3>
        <p class="plan-tag">Cuando quieras todo automático</p>
        <ul class="plan-list">
          <li>Sincronización por correo</li>
          <li>Categorización con IA</li>
          <li>Cuentas y bancos ilimitados</li>
          <li>Analítica avanzada y patrimonio</li>
          <li>Multi-dispositivo</li>
        </ul>
      </div>
    </div>
    <div class="offer reveal">
      <span class="os-eb" id="os-eb-date">¿Entras antes del 30 de junio? Eres pionero</span>
      <p class="offer-lead"><strong>No pagas nada</strong> por la beta —y además te llevas esto:</p>
      <ul class="offer-stack">
        <li>
          <span class="os-ic" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg></span>
          <span><strong>Presu completo, gratis</strong> — todas las funciones de la beta, sin pagar nada.</span>
        </li>
        <li>
          <span class="os-tag">Bono</span>
          <span><strong>Guía para ordenar tu plata</strong> — un PDF corto de Asimétrica para dejar tus finanzas en orden, apenas entras.</span>
        </li>
        <li>
          <span class="os-tag">Bono</span>
          <span><strong>Sesión en vivo con Asimétrica</strong> — resuelves tus dudas de plata con el equipo, en directo.</span>
        </li>
        <li>
          <span class="os-tag">Bono</span>
          <span><strong>Tu precio de pionero, para siempre</strong> — cuando el plan completo sea de pago, mantienes una tarifa especial.</span>
        </li>
        <li>
          <span class="os-tag">Bono</span>
          <span><strong>Decides qué sigue</strong> — pides qué banco o función construimos después.</span>
        </li>
      </ul>
      <p class="offer-note">Los precios del plan completo se definen al lanzar. Quien entre por la lista lo sabrá primero.</p>
    </div>
  </Section>

  <!-- ══════════════════ 8 · FAQ ══════════════════ -->
  <Section eyebrow="Preguntas frecuentes">
    <div class="sec-head reveal">
      <h2>Lo que la gente nos pregunta.</h2>
    </div>
    <div class="faq reveal">
      {faqs.map((f) => (
        <FaqItem question={f.q} answer={f.a} open={f.open} />
      ))}
    </div>
  </Section>

  <!-- ══════════════════ 9 · CTA FINAL / NUEVA OLA ══════════════════ -->
  <Section id="waitlist" eyebrow="La Nueva Ola">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="sec-head reveal">
      <h2>Sé de los primeros en usar <span class="mark">Presu</span>.</h2>
      <p class="sec-lead" id="waitlist-lede">La beta abre el <b>martes 30 de junio</b>. Los pioneros entran antes y usan Presu completo gratis —más unos bonos— a cambio de su feedback. Sin spam.</p>
      <div class="proof hidden" id="proof-wait">
        <span class="avatars" aria-hidden="true"><i class="av"></i><i class="av"></i><i class="av"></i><i class="av"></i></span>
        <b class="count">—</b><span class="proof-txt">&nbsp;personas ya en la Nueva Ola</span>
      </div>
    </div>

    <div class="formcard reveal">
      <form id="waitlist-form" novalidate>
        <fieldset class="segmented" id="perfil-group">
          <legend>Soy</legend>
          <label class="seg"><input type="radio" name="perfil" value="persona" checked /> <span>Persona</span></label>
          <label class="seg"><input type="radio" name="perfil" value="empresa" /> <span>Empresa</span></label>
        </fieldset>

        <div class="field">
          <label for="email">Correo <span aria-hidden="true" class="req">*</span></label>
          <input type="email" id="email" name="email" autocomplete="email" placeholder="tu@correo.com" required aria-required="true" />
          <p class="err" id="email-err">Revisa el correo —parece que le falta algo.</p>
        </div>

        <div class="field">
          <label for="nombre">Nombre <span class="opt">(opcional)</span></label>
          <input type="text" id="nombre" name="nombre" autocomplete="name" placeholder="Tu nombre" />
        </div>

        <div id="empresa-fields" class="hidden">
          <div class="field"><label for="empresa">Nombre de la empresa</label><input type="text" id="empresa" name="empresa" autocomplete="organization" placeholder="Tu empresa" /></div>
          <div class="field"><label for="empleados">N.º aproximado de empleados</label><input type="number" id="empleados" name="empleados" min="1" inputmode="numeric" placeholder="Ej. 50" /></div>
        </div>

        <div class="field consent">
          <input type="checkbox" id="consent" name="consent" required aria-required="true" />
          <label for="consent">Autorizo el tratamiento de mis datos según la <a href="/privacidad" target="_blank" rel="noopener">política de privacidad</a>.</label>
        </div>
        <p class="err" id="consent-err">Solo falta tu visto bueno aquí para sumarte.</p>

        <input type="text" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <button type="submit" class="capture-btn capture-btn--block">Únete a la lista de espera</button>
        <p class="err err--center" id="wl-err">Algo falló de nuestro lado. Reintenta en un momento.</p>
        <p class="form-foot">Mac y Windows · móvil próximamente · Presu, de Asimétrica</p>
      </form>

      <div id="waitlist-success" class="success hidden" role="status">
        <span class="success-ic" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"></path></svg></span>
        <h3>¡Listo, ya estás dentro!</h3>
        <p>Te escribimos primero cuando abramos cupos. Tu plata, clara —muy pronto.</p>
      </div>
    </div>
  </Section>

  <!-- ══════════════ ENCUESTA POST-REGISTRO (modal, oculto por defecto) ══════════════ -->
  <div id="connect-modal" class="connect-modal" role="dialog" aria-modal="true" aria-label="Cuéntanos un poco más">
    <div class="connect-modal__card">
      <button type="button" class="connect-modal__close" aria-label="Ahora no">Ahora no</button>
      <iframe title="Conectemos con Presu" allow="clipboard-write"></iframe>
    </div>
  </div>
</Base>

<!-- Estilos globales: los tocan/inyectan countdown.js y waitlist.js
     (el .mark inicial se vuelve .mintword tras el flip; el badge inyecta .ping). -->
<style is:global>
  .mark,
  .mintword {
    position: relative;
    color: var(--presu-emerald);
    white-space: nowrap;
  }
  .mark::after,
  .mintword::after {
    content: '';
    position: absolute;
    left: -0.05em;
    right: -0.05em;
    bottom: 0.05em;
    height: 0.12em;
    border-radius: 999px;
    background: var(--presu-emerald);
    opacity: 0.85;
    transform: rotate(-1.4deg);
    transform-origin: left center;
  }
  .ping {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--presu-emerald);
    box-shadow: 0 0 10px var(--presu-emerald);
    animation: presu-blink 2s infinite;
  }
</style>

<style>
