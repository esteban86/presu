  .capture-btn.loading {
    opacity: 0.65;
    pointer-events: none;
  }
  .capture-btn--block {
    width: 100%;
    margin-top: var(--space-2);
  }
  .capture-err {
    display: none;
    margin: var(--space-2) 0 0;
