---
import StaticPage from '../layouts/StaticPage.astro';
---
<StaticPage title="Admin · Presu" description="Panel de administración de Presu." noindex={true} analytics={false}>
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Hanken+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />

  <div class="brand">presu<span>.</span></div>
  <div class="eb">Admin</div>
  <div id="app"></div>

  <style is:global>
    :root{--mint:#34D399;--mint-bright:#5EEAB8;--ink:#08231A;--tx:#F4F4F3;--mut:#A1A1A6;--mut2:#6B6B72;--bg:#08080A;--bg2:#101014;--bg3:#16161A;--line:rgba(255,255,255,.1);--line2:rgba(255,255,255,.16);--head:"Space Grotesk",sans-serif;--mono:"JetBrains Mono",monospace}
    *{box-sizing:border-box}
    body{margin:0;background:var(--bg);color:var(--tx);font-family:"Hanken Grotesk",sans-serif;line-height:1.5;padding:28px 20px;max-width:1100px;margin:0 auto}
    .brand{font-family:var(--head);font-weight:700;font-size:22px;letter-spacing:-.02em}.brand span{color:var(--mint)}
    .eb{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--mint);margin:6px 0 18px}
    h1{font-family:var(--head);font-weight:700;font-size:1.7rem;letter-spacing:-.02em;margin:0 0 4px}
    .row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
    input{background:var(--bg2);border:1.5px solid var(--line);border-radius:11px;color:#fff;font-family:inherit;font-size:1rem;padding:11px 13px;outline:none;min-width:280px}
    input:focus{border-color:var(--mint)}
    .btn{border:0;border-radius:11px;padding:11px 18px;font-weight:700;font-size:.95rem;cursor:pointer;font-family:inherit;background:var(--mint);color:var(--ink);text-decoration:none;display:inline-block}
    .btn:hover{background:var(--mint-bright)}
    .btn.ghost{background:rgba(255,255,255,.05);border:1px solid var(--line2);color:#fff}
    .muted{color:var(--mut)}
    .stat{font-family:var(--mono);color:var(--mint-bright)}
    .group{background:var(--bg2);border:1px solid var(--line);border-radius:16px;padding:16px 18px;margin:14px 0}
    .ghead{display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:12px}
    .ghead b{font-family:var(--head);font-size:1.05rem}
    .tag{font-family:var(--mono);font-size:.72rem;color:var(--mut);background:var(--bg3);border:1px solid var(--line);border-radius:7px;padding:3px 8px}
    .pages{display:flex;gap:12px;flex-wrap:wrap}
    .pg{width:180px}
    .pg a{display:block;border:1px solid var(--line2);border-radius:10px;overflow:hidden;background:#000}
    .pg img{width:100%;height:230px;object-fit:cover;display:block}
    .pmeta{font-size:.78rem;color:var(--mut2);margin-top:5px;display:flex;justify-content:space-between;gap:6px;font-family:var(--mono)}
    .pmeta a{color:var(--mint-bright);text-decoration:none}
    .err{color:#FCA5A5;margin-top:10px}
    .empty{color:var(--mut2);margin-top:24px}
    .tabs{display:flex;gap:8px;margin:0 0 16px}
    .tab{font-family:var(--head);font-weight:600;font-size:.95rem;background:transparent;border:1px solid var(--line2);color:var(--mut);border-radius:999px;padding:8px 18px;cursor:pointer}
    .tab.on{background:var(--mint);border-color:var(--mint);color:var(--ink)}
    .chips{display:flex;gap:7px;flex-wrap:wrap;margin:4px 0 10px}
    .chip{font-family:var(--mono);font-size:.74rem;color:var(--tx);background:var(--bg3);border:1px solid var(--line);border-radius:8px;padding:4px 9px}
    .chip b{color:var(--mint-bright)}
    .agg-k{font-family:var(--mono);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mut2);margin:10px 0 4px}
    .kv{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:8px 16px;margin-top:8px}
    .kv .k{color:var(--mut2);font-family:var(--mono);font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;display:block}
    .kv div{font-size:.92rem}
    .st-ok{color:var(--mint-bright)} .st-part{color:#FCD34D}
    a.wa{color:var(--mint-bright);text-decoration:none}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin:14px 0}
    .scard{background:var(--bg2);border:1px solid var(--line);border-radius:16px;padding:16px 18px;cursor:pointer;transition:border-color .15s,background .15s}
    .scard:hover{border-color:var(--line2)}
    .scard.sel{border-color:var(--mint-bright);background:var(--bg3)}
    .scard[data-f="t"].sel{border-color:#7DD3FC}
    .scard .n{font-family:var(--head);font-weight:700;font-size:2.1rem;letter-spacing:-.02em}
    .scard .l{font-family:var(--mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--mut2);margin-top:2px}
    .c-mint{color:var(--mint-bright)} .c-sky{color:#7DD3FC}
    .legend{display:flex;gap:16px;flex-wrap:wrap;font-size:.82rem;color:var(--mut);font-family:var(--mono)}
    .dot{display:inline-block;width:9px;height:9px;border-radius:3px;margin-right:6px;vertical-align:baseline}
    .ucards{display:flex;gap:12px;flex-wrap:wrap;margin:8px 0}
    .ucard{flex:1 1 160px;background:#141418;border:1px solid #2a2a30;border-radius:12px;padding:14px}
    .uck{font-weight:700;margin-bottom:8px;color:#34D399}
    .ucrow{display:flex;justify-content:space-between;font-size:.9rem;color:#bbb;padding:2px 0}
    .ucrow b{color:#fff}
    .tablewrap{overflow-x:auto}
    .utable{width:100%;border-collapse:collapse;font-size:.9rem}
    .utable th,.utable td{text-align:left;padding:8px;border-bottom:1px solid #222}
    .utable td.c{text-align:center}
    .urow{cursor:pointer}.urow:hover{background:#161616}
    .umodal{position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:50;padding:16px}
    .ubox{background:#0f0f12;border:1px solid #2a2a30;border-radius:16px;max-width:560px;width:100%;max-height:85vh;overflow:auto;padding:24px;position:relative}
    .uclose{position:absolute;top:12px;right:14px;background:none;border:0;color:#888;font-size:1.1rem;cursor:pointer}
    .umeta{color:#9a9a9a;font-size:.86rem;margin:2px 0 10px}
    .uwarn{background:#3a1414;border:1px solid #5a2020;color:#f3a;border-radius:8px;padding:8px 12px;margin:8px 0;font-size:.85rem}
    .ustats{display:flex;gap:16px;margin:10px 0;font-size:.9rem;color:#bbb}.ustats b{color:#fff}
    .uev{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #1c1c1c;font-size:.88rem}
    .uet{min-width:120px}.uec{color:#34D399;flex:1}.uedate{color:#777;font-size:.8rem}
  </style>

  <script is:inline>
  (function(){
    var API = ['presu.asimetrica.co','presu.io','www.presu.io','presu.com.co'].indexOf(location.hostname) !== -1
      ? 'https://presu-waitlist.asimetrica.workers.dev'
      : 'https://presu-waitlist-staging.asimetrica.workers.dev';
    var app = document.getElementById('app');
    var tok = sessionStorage.getItem('presu_admin_tok') || '';
    var GROUPS = {};
    var view = location.hash === '#encuesta' ? 'encuesta' : (location.hash === '#registros' ? 'registros' : (location.hash === '#clics' ? 'clics' : (location.hash === '#usuarios' ? 'usuarios' : 'aportes')));
    function esc(s){return String(s==null?'':s).replace(/[&<>"]/g,function(c){return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c];});}

    // Junta las páginas de un envío en UN solo PDF (en el navegador).
    function loadJsPDF(){ if(window.jspdf&&window.jspdf.jsPDF) return Promise.resolve(); if(loadJsPDF._p) return loadJsPDF._p; loadJsPDF._p=new Promise(function(res,rej){ var s=document.createElement('script'); s.src='https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js'; s.onload=res; s.onerror=rej; document.head.appendChild(s); }); return loadJsPDF._p; }
    function loadJSZip(){ if(window.JSZip) return Promise.resolve(); if(loadJSZip._p) return loadJSZip._p; loadJSZip._p=new Promise(function(res,rej){ var s=document.createElement('script'); s.src='https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js'; s.onload=res; s.onerror=rej; document.head.appendChild(s); }); return loadJSZip._p; }
    function pdfName(g){ var f=g[0]; return (f.banco||'doc').toLowerCase().replace(/[^a-z0-9]+/g,'-')+'_'+String(f.submissionId||f.id).slice(0,8)+'.pdf'; }
    // Arma UN jsPDF con todas las páginas (imágenes) de un envío.
    function buildPdf(g){
      var JsPDF=(window.jspdf&&window.jspdf.jsPDF)||window.jsPDF;
      return Promise.all(g.map(function(r){
        var pImg=new Promise(function(res){ var im=new Image(); im.crossOrigin='anonymous'; im.onload=function(){res(im);}; im.onerror=function(){res(null);}; im.src=API+'/admin/doc?id='+encodeURIComponent(r.id)+'&t='+encodeURIComponent(tok)+'&c=1'; });
        var pTok=fetch(API+'/admin/doc?id='+encodeURIComponent(r.id)+'&t='+encodeURIComponent(tok)+'&kind=json').then(function(x){return x.json();}).catch(function(){return null;});
        return Promise.all([pImg,pTok]).then(function(a){ return { img:a[0], lay:a[1] }; });
      })).then(function(pages){
        pages=pages.filter(function(p){return p.img;}); // imagen faltante → se omite
        if(!pages.length) return null;
        var doc;
        pages.forEach(function(p,i){ var im=p.img, w=im.naturalWidth, h=im.naturalHeight, o=w>h?'l':'p';
          if(i===0){ doc=new JsPDF({unit:'px',format:[w,h],orientation:o}); } else { doc.addPage([w,h],o); }
          doc.addImage(im,'JPEG',0,0,w,h);
          // Capa de texto INVISIBLE con los tokens anónimos (posicionados) → pdftotext/parsers lo leen.
          var lay=p.lay;
          if(lay && lay.tokens && lay.tokens.length){
            var sx=lay.w?(w/lay.w):1, sy=lay.h?(h/lay.h):1;
            lay.tokens.forEach(function(t){ if(!t.t) return;
              var fs=Math.max(1,(t.h||10)*sy*0.72);
              try{ doc.setFontSize(fs); doc.text(String(t.t), t.x*sx, (t.y+(t.h||fs)*0.8)*sy, {renderingMode:'invisible'}); }catch(e){}
            });
          }
        });
        return doc;
      });
    }
    function sortPages(sid){ return (GROUPS[sid]||[]).slice().sort(function(a,b){return (a.page||0)-(b.page||0);}); }
    function downloadPdf(sid, banco, btn){
      var g=sortPages(sid); if(!g.length) return;
      var orig=btn.textContent; btn.disabled=true; btn.textContent='Generando…';
      loadJsPDF().then(function(){ return buildPdf(g); }).then(function(doc){ if(doc) doc.save(pdfName(g)); else alert('No hay imágenes disponibles para este documento.'); btn.disabled=false; btn.textContent=orig; })
        .catch(function(e){ btn.disabled=false; btn.textContent=orig; alert('No se pudo generar el PDF: '+(e&&e.message||e)); });
    }
    // Junta cada envío en su PDF y los mete todos en un .zip.
    function downloadAll(btn){
      var sids=Object.keys(GROUPS); if(!sids.length) return;
      var orig=btn.textContent; btn.disabled=true;
      Promise.all([loadJsPDF(), loadJSZip()]).then(function(){
        var zip=new JSZip(), i=0;
        function next(){
          if(i>=sids.length){ btn.textContent='Comprimiendo…'; return zip.generateAsync({type:'blob'}).then(function(blob){ var u=URL.createObjectURL(blob); var a=document.createElement('a'); a.href=u; a.download='presu-aportes-pdfs.zip'; a.click(); URL.revokeObjectURL(u); }); }
          btn.textContent='PDF '+(i+1)+'/'+sids.length+'…';
          var g=sortPages(sids[i]);
          return buildPdf(g).then(function(doc){ if(doc) zip.file(pdfName(g), doc.output('arraybuffer')); i++; return next(); }).catch(function(){ i++; return next(); });
        }
        return next();
      }).then(function(){ btn.disabled=false; btn.textContent=orig; })
        .catch(function(e){ btn.disabled=false; btn.textContent=orig; alert('No se pudo armar el zip: '+(e&&e.message||e)); });
    }

    // ── Tabs (Aportes | Encuesta) ──
    function tabs(){
      return '<div class="tabs">'+
        '<button class="tab'+(view==='aportes'?' on':'')+'" data-v="aportes">Aportes</button>'+
        '<button class="tab'+(view==='encuesta'?' on':'')+'" data-v="encuesta">Encuesta</button>'+
        '<button class="tab'+(view==='registros'?' on':'')+'" data-v="registros">Registros</button>'+
        '<button class="tab'+(view==='clics'?' on':'')+'" data-v="clics">Clics</button>'+
        '<button class="tab'+(view==='usuarios'?' on':'')+'" data-v="usuarios">Usuarios</button></div>';
    }
    function wireTabs(){
      Array.prototype.forEach.call(document.querySelectorAll('.tab'), function(b){
        b.onclick=function(){ view=b.getAttribute('data-v'); location.hash = view==='aportes' ? '' : '#'+view; load(); };
      });
    }

    function gate(msg){
      app.innerHTML = '<h1>Entrar</h1><p class="muted">Pega el token de admin para entrar.</p>'+
        '<div class="row"><input id="tk" type="password" placeholder="X-Admin-Token" value="'+esc(tok)+'"><button class="btn" id="go">Entrar</button></div>'+
        (msg?'<p class="err">'+esc(msg)+'</p>':'');
      document.getElementById('go').onclick=function(){ tok=document.getElementById('tk').value.trim(); sessionStorage.setItem('presu_admin_tok',tok); load(); };
      document.getElementById('tk').addEventListener('keydown',function(e){ if(e.key==='Enter') document.getElementById('go').click(); });
    }

    function load(){
      if(!tok){ return gate(); }
      app.innerHTML='<p class="muted">Cargando…</p>';
      if(view==='encuesta'){
        fetch(API+'/admin/survey',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){ if(r.status===401) throw new Error('Token inválido'); return r.json(); })
          .then(function(d){ renderSurvey(d.rows||[]); })
          .catch(function(e){ gate(e.message||'No se pudo cargar'); });
        return;
      }
      if(view==='registros'){
        fetch(API+'/admin/waitlist',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){ if(r.status===401) throw new Error('Token inválido'); return r.json(); })
          .then(function(d){ renderRegistros(d.rows||[]); })
          .catch(function(e){ gate(e.message||'No se pudo cargar'); });
        return;
      }
      if(view==='clics'){
        fetch(API+'/admin/clicks',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){ if(r.status===401) throw new Error('Token inválido'); return r.json(); })
          .then(function(d){ renderClics(d); })
          .catch(function(e){ gate(e.message||'No se pudo cargar'); });
        return;
      }
      if(view==='usuarios'){
        fetch(API+'/admin/users',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){ if(r.status===401) throw new Error('Token inválido'); return r.json(); }).then(function(d){ renderUsuarios(d); })
          .catch(function(e){ gate(e.message||'Error cargando usuarios'); });
        return;
      }
      fetch(API+'/admin/contrib',{headers:{'X-Admin-Token':tok},cache:'no-store'})
        .then(function(r){ if(r.status===401) throw new Error('Token inválido'); return r.json(); })
        .then(function(d){ render(d.rows||[]); })
        .catch(function(e){ gate(e.message||'No se pudo cargar'); });
    }

    // ── Vista Encuesta ──
    // Campos en el orden del formulario (encuesta.html); los de texto libre van aparte.
    var SV_FIELDS=[['edad','Edad'],['ciudad','Ciudad'],['ocupacion','Ocupación'],['ingreso_tipo','Ingreso'],
      ['metodo','Método hoy'],['metas','Metas'],['bancos','Bancos'],['dispositivo','Teléfono'],
      ['pago','Pagaría'],['ingreso','Rango ingreso'],['ayuda','Ayuda ofrecida'],['uso','Usa Presu'],['features','Features'],['ayuda_config','Ayuda config']];
    var SV_FREE=[['dolor','Frustración'],['valor','Lo que más le sirve'],['falta','Lo que le falta']];
    function svVal(v){ return esc(Array.isArray(v)?v.join(', '):String(v)); }
    function svDate(ts){ return ts?new Date(ts).toLocaleString('es-CO',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}):''; }
    function tally(rows,field){
      var m={}; rows.forEach(function(r){ var v=r[field]; if(v==null||v==='') return;
        (Array.isArray(v)?v:[v]).forEach(function(x){ m[x]=(m[x]||0)+1; }); });
      return Object.keys(m).sort(function(a,b){return m[b]-m[a];})
        .map(function(k){return '<span class="chip">'+esc(k)+' <b>'+m[k]+'</b></span>';}).join('');
    }
    function svCsv(rows){
      var cols=['email','completed','ts','nombre'].concat(SV_FIELDS.map(function(f){return f[0];})).concat(SV_FREE.map(function(f){return f[0];})).concat(['celular','origen','perfil','referrals']);
      var esc2=function(v){ v=Array.isArray(v)?v.join('; '):(v==null?'':String(v)); return '"'+v.replace(/"/g,'""')+'"'; };
      var lines=[cols.join(',')].concat(rows.map(function(r){ return cols.map(function(c){ return esc2(c==='ts'?svDate(r.ts):r[c]); }).join(','); }));
      var b=new Blob(['﻿'+lines.join('\r\n')],{type:'text/csv;charset=utf-8'}); var u=URL.createObjectURL(b);
      var a=document.createElement('a'); a.href=u; a.download='presu-encuesta.csv'; a.click(); URL.revokeObjectURL(u);
    }
    function renderSurvey(rows){
      var comp=rows.filter(function(r){return r.completed;}).length;
      var html=tabs()+'<h1>Encuesta <span class="stat">'+rows.length+' respuestas · '+comp+' completas · '+(rows.length-comp)+' parciales</span></h1>'+
        '<div class="row" style="margin:10px 0 6px"><button class="btn ghost" id="csv">⬇ CSV</button> '+
        '<button class="btn ghost" id="reload">Recargar</button> <button class="btn ghost" id="logout">Salir</button></div>';
      if(!rows.length){ app.innerHTML=html+'<p class="empty">Aún no hay respuestas.</p>'; wireSurvey(rows); return; }
      html+='<div class="group"><div class="ghead"><b>Resumen</b></div>'+
        '<div class="agg-k">Bancos</div><div class="chips">'+(tally(rows,'bancos')||'—')+'</div>'+
        '<div class="agg-k">Pagarían</div><div class="chips">'+(tally(rows,'pago')||'—')+'</div>'+
        '<div class="agg-k">Metas</div><div class="chips">'+(tally(rows,'metas')||'—')+'</div>'+
        '<div class="agg-k">Teléfono</div><div class="chips">'+(tally(rows,'dispositivo')||'—')+'</div>'+
        '<div class="agg-k">Ayuda ofrecida</div><div class="chips">'+(tally(rows,'ayuda')||'—')+'</div></div>';
      rows.forEach(function(r){
        var est=r.completed?'<span class="tag st-ok">completa ✓</span>':'<span class="tag st-part">parcial ✎</span>';
        var wa=r.celular?String(r.celular).replace(/[^0-9]/g,''):'';
        html+='<div class="group"><div class="ghead"><b>'+esc(r.nombre||'(sin nombre)')+' <span class="muted" style="font-weight:400">· '+esc(r.email)+'</span></b>'+
          '<span>'+est+' <span class="tag">'+svDate(r.ts)+'</span>'+(r.origen?' <span class="tag">'+esc(r.origen)+'</span>':'')+(r.referrals?' <span class="tag">'+r.referrals+' referidos</span>':'')+
          (wa?' <a class="btn wa" style="padding:6px 12px;font-size:.85rem" href="https://wa.me/'+wa+'" target="_blank" rel="noopener">WhatsApp</a>':'')+'</span></div><div class="kv">';
        SV_FIELDS.forEach(function(f){ if(r[f[0]]!=null&&r[f[0]]!=='') html+='<div><span class="k">'+f[1]+'</span>'+svVal(r[f[0]])+'</div>'; });
        if(r.celular) html+='<div><span class="k">WhatsApp</span><a class="wa" href="https://wa.me/'+wa+'" target="_blank" rel="noopener">'+esc(r.celular)+'</a></div>';
        html+='</div>';
        SV_FREE.forEach(function(f){ if(r[f[0]]) html+='<p class="muted" style="margin:8px 0 0;border-left:2px solid var(--line2);padding-left:10px"><b>'+f[1]+':</b> '+esc(r[f[0]])+'</p>'; });
        html+='</div>';
      });
      app.innerHTML=html; wireSurvey(rows);
    }
    function wireSurvey(rows){
      wireTabs();
      var c=document.getElementById('csv'); if(c) c.onclick=function(){ svCsv(rows); };
      var rl=document.getElementById('reload'); if(rl) rl.onclick=load;
      var lo=document.getElementById('logout'); if(lo) lo.onclick=function(){ sessionStorage.removeItem('presu_admin_tok'); tok=''; gate(); };
    }

    // ── Vista Registros (waitlist: Pioneros vs Nueva Ola) ──
    var C_MINT='#34D399', C_SKY='#7DD3FC';
    function regDay(ts){ return new Date(ts).toLocaleDateString('en-CA',{timeZone:'America/Bogota'}); } // YYYY-MM-DD
    function regDayLbl(iso){ var p=iso.split('-'); return new Date(Date.UTC(+p[0],+p[1]-1,+p[2],12)).toLocaleDateString('es-CO',{day:'numeric',month:'short'}); }
    function renderRegistros(rows){
      var pio=0, ola=0, byDay={}, sinFecha=0;
      rows.forEach(function(r){
        if(r.cohort==='tanda2') ola++; else pio++;          // contadores: TODOS los registros
        if(!r.ts){ sinFecha++; return; }                     // el gráfico solo puede ubicar los con fecha
        var d=regDay(r.ts); if(!byDay[d]) byDay[d]={p:0,t:0};
        if(r.cohort==='tanda2') byDay[d].t++; else byDay[d].p++; });
      var html=tabs()+'<h1>Registros <span class="stat">'+rows.length+' en la lista</span></h1>'+
        '<div class="row" style="margin:10px 0 6px"><button class="btn ghost" id="wcsv">⬇ CSV</button> '+
        '<button class="btn ghost" id="reload">Recargar</button> <button class="btn ghost" id="logout">Salir</button></div>'+
        '<div class="stats">'+
        '<div class="scard" data-f="p" title="Filtrar el gráfico: solo Pioneros"><div class="n c-mint">'+pio+'</div><div class="l">Pioneros 🌱</div></div>'+
        '<div class="scard" data-f="t" title="Filtrar el gráfico: solo Nueva Ola"><div class="n c-sky">'+ola+'</div><div class="l">Nueva Ola 🌊</div></div>'+
        '<div class="scard sel" data-f="all" title="Ver todo el consolidado"><div class="n">'+(pio+ola)+'</div><div class="l">Total consolidado</div></div></div>';
      var days=Object.keys(byDay).sort();
      if(days.length){
        // relleno de días vacíos para continuidad del eje
        var all=[], d0=new Date(days[0]+'T12:00:00Z'), d1=new Date(days[days.length-1]+'T12:00:00Z');
        for(var d=new Date(d0); d<=d1; d.setUTCDate(d.getUTCDate()+1)) all.push(d.toISOString().slice(0,10));
        html+='<div class="group"><div class="ghead"><b>Registros por día</b><span class="legend">'+
          '<span><span class="dot" style="background:'+C_MINT+'"></span>Pioneros</span>'+
          '<span><span class="dot" style="background:'+C_SKY+'"></span>Nueva Ola</span>'+
          '<span><span class="dot" style="background:#F4F4F3;height:3px;border-radius:2px"></span>Acumulado</span></span></div>'+
          '<canvas id="regChart" style="width:100%;height:280px;display:block"></canvas>'+
          (sinFecha?'<p class="muted" style="font-size:.82rem;margin:10px 0 0">'+sinFecha+' registros del import inicial no tienen fecha y no aparecen en el gráfico (sí cuentan arriba).</p>':'')+'</div>';
        app.innerHTML=html; regChart(all, byDay, 'all');
      } else {
        app.innerHTML=html+'<p class="empty">Aún no hay registros.</p>';
      }
      wireRegistros(byDay);
    }
    // Rango de días con datos para un filtro (rellena huecos intermedios)
    function regSpan(byDay, f){
      var ds=Object.keys(byDay).filter(function(d){ var v=byDay[d];
        return f==='p' ? v.p>0 : (f==='t' ? v.t>0 : (v.p+v.t)>0); }).sort();
      if(!ds.length) return [];
      var all=[], d0=new Date(ds[0]+'T12:00:00Z'), d1=new Date(ds[ds.length-1]+'T12:00:00Z');
      for(var d=new Date(d0); d<=d1; d.setUTCDate(d.getUTCDate()+1)) all.push(d.toISOString().slice(0,10));
      return all;
    }
    // filtro: 'all' (apiladas) | 'p' (solo Pioneros) | 't' (solo Nueva Ola)
    function regChart(days, byDay, filter){
      var cv=document.getElementById('regChart'); if(!cv) return;
      var dpr=window.devicePixelRatio||1, W=cv.clientWidth, H=cv.clientHeight;
      if(!W){ requestAnimationFrame(function(){ regChart(days, byDay, filter); }); return; } // layout aún no listo
      cv.width=W*dpr; cv.height=H*dpr;
      var x=cv.getContext('2d'); x.clearRect(0,0,W,H); x.scale(dpr,dpr);
      var L=36,R=44,T=12,B=30, pw=W-L-R, ph=H-T-B;
      var val=function(v){ return filter==='p'?v.p : filter==='t'?v.t : (v.p+v.t); };
      var maxBar=1, cum=0, cums=[];
      days.forEach(function(d){ var v=byDay[d]||{p:0,t:0}; maxBar=Math.max(maxBar,val(v)); cum+=val(v); cums.push(cum); });
      var maxCum=Math.max(1,cum);
      x.font='10px "JetBrains Mono",monospace'; x.textBaseline='middle';
      // grid + ejes (izq: diario, der: acumulado)
      for(var i=0;i<=4;i++){ var gy=T+ph-ph*i/4;
        x.strokeStyle='rgba(255,255,255,.07)'; x.beginPath(); x.moveTo(L,gy); x.lineTo(L+pw,gy); x.stroke();
        x.fillStyle='#6B6B72'; x.textAlign='right'; x.fillText(String(Math.round(maxBar*i/4)), L-6, gy);
        x.textAlign='left'; x.fillText(String(Math.round(maxCum*i/4)), L+pw+6, gy); }
      // barras
      var step=pw/days.length, bw=Math.max(2,Math.min(26,step*0.72));
      days.forEach(function(d,i){ var v=byDay[d]||{p:0,t:0}, cx=L+step*(i+0.5);
        var hp=ph*v.p/maxBar, ht=ph*v.t/maxBar;
        if(filter!=='t' && v.p){ x.fillStyle=C_MINT; x.fillRect(cx-bw/2, T+ph-hp, bw, hp); }
        if(filter!=='p' && v.t){ x.fillStyle=C_SKY; x.fillRect(cx-bw/2, T+ph-(filter==='t'?0:hp)-ht, bw, ht); } });
      // línea acumulada (escala derecha)
      x.strokeStyle='rgba(244,244,243,.9)'; x.lineWidth=1.5; x.beginPath();
      days.forEach(function(d,i){ var cx=L+step*(i+0.5), cy=T+ph-ph*cums[i]/maxCum; i?x.lineTo(cx,cy):x.moveTo(cx,cy); });
      x.stroke();
      // etiquetas X (~6)
      x.fillStyle='#6B6B72'; x.textAlign='center';
      var every=Math.max(1,Math.ceil(days.length/6));
      days.forEach(function(d,i){ if(i%every===0||i===days.length-1) x.fillText(regDayLbl(d), L+step*(i+0.5), T+ph+14); });
    }
    function wireRegistros(byDay){
      wireTabs();
      // Cards como filtro del gráfico
      Array.prototype.forEach.call(document.querySelectorAll('.scard[data-f]'), function(card){
        card.onclick=function(){
          var f=card.getAttribute('data-f');
          Array.prototype.forEach.call(document.querySelectorAll('.scard[data-f]'), function(c){ c.classList.toggle('sel', c===card); });
          regChart(regSpan(byDay, f), byDay, f);
        };
      });
      var c=document.getElementById('wcsv'); if(c) c.onclick=function(){
        fetch(API+'/admin/waitlist?format=csv',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){return r.text();}).then(function(t){
            var b=new Blob(['﻿'+t],{type:'text/csv;charset=utf-8'}); var u=URL.createObjectURL(b);
            var a=document.createElement('a'); a.href=u; a.download='presu-registros.csv'; a.click(); URL.revokeObjectURL(u);
          });
      };
      var rl=document.getElementById('reload'); if(rl) rl.onclick=load;
      var lo=document.getElementById('logout'); if(lo) lo.onclick=function(){ sessionStorage.removeItem('presu_admin_tok'); tok=''; gate(); };
    }

    // ── Vista Clics (tracking del link del correo: quién, device, destino) ──
    function clDate(ts){ return ts?new Date(ts).toLocaleString('es-CO',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}):''; }
    function clChips(o){ o=o||{}; var ks=Object.keys(o).sort(function(a,b){return o[b]-o[a];}); return ks.length?ks.map(function(k){return '<span class="chip">'+esc(k)+' <b>'+o[k]+'</b></span>';}).join(''):'—'; }
    function renderClics(d){
      d=d||{};
      var people=d.people||[];
      var html=tabs()+'<h1>Clics <span class="stat">'+(d.totalClicks||0)+' clics · '+(d.uniquePeople||0)+' personas</span></h1>'+
        '<div class="row" style="margin:10px 0 6px"><button class="btn ghost" id="reload">Recargar</button> <button class="btn ghost" id="logout">Salir</button></div>'+
        '<div class="group"><div class="ghead"><b>Resumen</b></div>'+
        '<div class="agg-k">Dispositivo</div><div class="chips">'+clChips(d.byDevice)+'</div>'+
        '<div class="agg-k">Destino</div><div class="chips">'+clChips(d.byTo)+'</div>'+
        '<div class="agg-k">Campaña</div><div class="chips">'+clChips(d.byCampaign)+'</div></div>';
      if(!people.length){ app.innerHTML=html+'<p class="empty">Aún no hay clics registrados.</p>'; wireClics(); return; }
      html+='<div class="group"><div class="ghead"><b>Por persona</b></div>';
      people.forEach(function(p){
        var tos=Object.keys(p.tos||{}).map(function(t){return '<span class="tag">'+esc(t)+': '+p.tos[t]+'</span>';}).join(' ');
        html+='<div style="border-bottom:1px solid var(--line);padding:9px 0"><b>'+esc(p.email)+'</b> '+
          '<span class="tag">'+p.clicks+' clic'+(p.clicks!==1?'s':'')+'</span> '+
          '<span class="tag">último: '+esc(p.lastDevice||'?')+'</span> '+
          '<span class="tag">'+clDate(p.lastAt)+'</span> '+tos+'</div>';
      });
      html+='</div>';
      app.innerHTML=html; wireClics();
    }
    function wireClics(){
      wireTabs();
      var rl=document.getElementById('reload'); if(rl) rl.onclick=load;
      var lo=document.getElementById('logout'); if(lo) lo.onclick=function(){ sessionStorage.removeItem('presu_admin_tok'); tok=''; gate(); };
    }

    // ── Vista Usuarios (resumen por campaña + tabla + buscador) ──
    function renderUsuarios(d){
      var rows = d.rows||[], camps = d.campaigns||[];
      var LABEL = { welcome:'Bienvenida', encuesta:'Encuesta', followup:'Seguimiento', campaign:'Lanzamiento' };
      function pct(n,den){ return den>0 ? Math.round(n/den*100)+'%' : '—'; }
      var order = ['welcome','encuesta','followup','campaign'];
      var cardMap = {}; camps.forEach(function(c){ cardMap[c.key]=c; });
      var cards = order.filter(function(k){return cardMap[k];}).map(function(k){
        var c = cardMap[k];
        return '<div class="ucard"><div class="uck">'+esc(LABEL[k]||k)+'</div>'+
          '<div class="ucrow"><span>Entregados</span><b>'+c.delivered+'</b></div>'+
          '<div class="ucrow"><span>Abiertos*</span><b>'+pct(c.openedUnique,c.delivered)+'</b></div>'+
          '<div class="ucrow"><span>Clic</span><b>'+pct(c.clickedUnique,c.delivered)+'</b></div>'+
          '<div class="ucrow"><span>Rebote</span><b>'+pct(c.bounced,c.delivered+c.bounced)+'</b></div></div>';
      }).join('');
      function ico(b){ return b?'✓':'·'; }
      var body = rows.map(function(u){
        var enc = u.survey.completed?'✓':(u.survey.answered?'parcial':'—');
        var warn = (u.bounced||u.complained)?' ⚠️':'';
        return '<tr data-e="'+esc(u.email)+'" data-n="'+esc((u.nombre||'').toLowerCase())+'" class="urow">'+
          '<td>'+esc(u.email)+warn+'</td>'+
          '<td>'+esc(u.cohort)+'</td>'+
          '<td class="c">'+ico(u.sent.welcome)+ico(u.sent.encuesta)+ico(u.sent.followup)+'</td>'+
          '<td class="c">'+(u.delivered?'✓':'·')+'</td>'+
          '<td class="c">'+(u.opens||0)+'</td>'+
          '<td class="c">'+(u.clicks||0)+'</td>'+
          '<td class="c">'+enc+'</td></tr>';
      }).join('');
      app.innerHTML = tabs()+
        '<h1>Usuarios <span class="stat">'+rows.length+' personas</span></h1>'+
        '<div class="ucards">'+cards+'</div>'+
        '<p class="muted" style="font-size:.8rem">*Aperturas aprox. — Apple Mail pre-carga imágenes. El clic es la señal fuerte.</p>'+
        '<input id="usearch" placeholder="Buscar correo o nombre…" style="width:100%;margin:12px 0;padding:10px;border-radius:10px;border:1px solid #333;background:#111;color:#fff">'+
        '<div class="tablewrap"><table class="utable"><thead><tr><th>Correo</th><th>Cohorte</th><th>Enviados</th><th>Entreg.</th><th>Aperturas</th><th>Clics</th><th>Encuesta</th></tr></thead><tbody id="ubody">'+body+'</tbody></table></div>';
      wireUsuarios();
    }
    function wireUsuarios(){
      wireTabs();
      var search = document.getElementById('usearch');
      if (search) search.oninput = function(){
        var q = search.value.trim().toLowerCase();
        document.querySelectorAll('#ubody tr').forEach(function(tr){
          var hit = tr.getAttribute('data-e').toLowerCase().indexOf(q) > -1 || tr.getAttribute('data-n').indexOf(q) > -1;
          tr.style.display = hit ? '' : 'none';
        });
      };
      document.querySelectorAll('#ubody tr.urow').forEach(function(tr){
        tr.onclick = function(){ openUserProfile(tr.getAttribute('data-e')); };
      });
    }

    // ── Perfil de usuario (modal): registro + línea de tiempo de correo/clics ──
    function openUserProfile(email){
      var overlay = document.createElement('div'); overlay.className='umodal';
      overlay.innerHTML = '<div class="ubox"><button class="uclose">✕</button><div id="uprofile" class="muted">Cargando…</div></div>';
      document.body.appendChild(overlay);
      overlay.querySelector('.uclose').onclick = function(){ overlay.remove(); };
      overlay.onclick = function(e){ if(e.target===overlay) overlay.remove(); };
      fetch(API+'/admin/user?e='+encodeURIComponent(email),{headers:{'X-Admin-Token':tok},cache:'no-store'})
        .then(function(r){return r.json();}).then(function(d){
          var prof = document.getElementById('uprofile'); if(!prof) return; // modal cerrado antes de resolver
          var TL = { delivered:'📬 Entregado', opened:'👀 Abierto', clicked:'🖱️ Clic', bounced:'⛔ Rebote', complained:'🚩 Spam' };
          var CL = { welcome:'Bienvenida', encuesta:'Encuesta', followup:'Seguimiento', campaign:'Lanzamiento', '':'—' };
          function fdate(ts){ if(!ts) return ''; var d=new Date(ts); return d.toLocaleString('es-CO'); }
          var tl = (d.timeline||[]).map(function(ev){
            return '<div class="uev"><span class="uet">'+(TL[ev.t]||ev.t)+'</span> <span class="uec">'+esc(CL[ev.c]!=null?CL[ev.c]:ev.c)+'</span><span class="uedate">'+fdate(ev.ts)+'</span></div>';
          }).join('') || '<p class="muted">Sin eventos de correo todavía.</p>';
          var u = d.user||{};
          var warn = (u.bouncedAt||u.complainedAt) ? '<div class="uwarn">⚠️ '+(u.bouncedAt?'Rebotó':'')+(u.complainedAt?' · marcó spam':'')+'</div>' : '';
          prof.className='';
          prof.innerHTML =
            '<h2>'+esc(u.nombre||u.email)+'</h2>'+
            '<p class="umeta">'+esc(u.email)+' · '+esc(d.cohort||'')+' · registrado '+fdate(u.signupTs)+'</p>'+
            warn+
            '<div class="ustats"><span>Aperturas: <b>'+(u.openCount||0)+'</b></span> <span>Encuesta: <b>'+(d.survey&&d.survey.completed?'completa':(d.survey&&d.survey.answered?'parcial':'—'))+'</b></span></div>'+
            '<h3>Línea de tiempo</h3>'+tl;
        }).catch(function(){ var p=document.getElementById('uprofile'); if(p) p.innerHTML='Error cargando el perfil.'; });
    }

    function render(rows){
      // agrupar por submissionId
      GROUPS={}; var groups=GROUPS, order=[];
      rows.forEach(function(r){ var k=r.submissionId||r.id; if(!groups[k]){ groups[k]=[]; order.push(k); } groups[k].push(r); });
      var exportUrl = API+'/admin/contrib/export';
      var head = tabs()+'<h1>Aportes <span class="stat">'+rows.length+' docs · '+order.length+' envíos</span></h1>'+
        '<div class="row" style="margin:10px 0 6px"><button class="btn" id="dlall">📦 Descargar todo (PDFs .zip)</button> '+
        '<button class="btn ghost" id="exp">⬇ Dataset (JSONL)</button> '+
        '<button class="btn ghost" id="reload">Recargar</button> '+
        '<button class="btn ghost" id="logout">Salir</button></div>';
      if(!rows.length){ app.innerHTML=head+'<p class="empty">Aún no hay aportes.</p>'; wire(); return; }
      var html=head;
      order.forEach(function(k){
        var g=groups[k].sort(function(a,b){return (a.page||0)-(b.page||0);});
        var f=g[0];
        html+='<div class="group"><div class="ghead"><b>'+esc(f.banco||'?')+'</b>'+
          '<span><span class="tag">'+esc(f.pais||'')+'</span> <span class="tag">'+esc(f.moneda||'')+'</span> <span class="tag">'+esc(f.tipo||'')+'</span> <span class="tag">'+g.length+' pág</span> <button class="btn pdf-btn" style="padding:7px 13px;font-size:.85rem" data-sid="'+esc(k)+'" data-banco="'+esc(f.banco||'doc')+'">📄 Descargar PDF</button></span></div><div class="pages">';
        g.forEach(function(r){
          var img=API+'/admin/doc?id='+encodeURIComponent(r.id)+'&t='+encodeURIComponent(tok);
          html+='<div class="pg"><a href="'+img+'" target="_blank" rel="noopener"><img loading="lazy" src="'+img+'"></a>'+
            '<div class="pmeta"><span>'+(r.source||'')+' · '+(r.tokenCount||0)+' tok</span></div></div>';
        });
        html+='</div></div>';
      });
      app.innerHTML=html; wire();
    }

    function wire(){
      wireTabs();
      var ex=document.getElementById('exp'); if(ex) ex.onclick=function(){
        fetch(API+'/admin/contrib/export',{headers:{'X-Admin-Token':tok},cache:'no-store'})
          .then(function(r){return r.text();}).then(function(t){
            var b=new Blob([t],{type:'application/x-ndjson'}); var u=URL.createObjectURL(b);
            var a=document.createElement('a'); a.href=u; a.download='presu-aportes.jsonl'; a.click(); URL.revokeObjectURL(u);
          });
      };
      var rl=document.getElementById('reload'); if(rl) rl.onclick=load;
      var lo=document.getElementById('logout'); if(lo) lo.onclick=function(){ sessionStorage.removeItem('presu_admin_tok'); tok=''; gate(); };
      Array.prototype.forEach.call(document.querySelectorAll('.pdf-btn'), function(b){ b.onclick=function(){ downloadPdf(b.getAttribute('data-sid'), b.getAttribute('data-banco'), b); }; });
      var da=document.getElementById('dlall'); if(da) da.onclick=function(){ downloadAll(da); };
    }

    load();
  })();
  </script>
</StaticPage>
